  createdAt         DateTime  @default(now())
  createdBy         String?
  updatedAt         DateTime  @updatedAt
  updatedBy         String?
  deletedAt         DateTime?
  deletedBy         String?
  version           Int       @default(1)
  programId         String?
  academicSessionId String?
  classroomId       String?
  curriculumId      String?
  lessonPlanId      String?
  observerId        String?
  observationId     String?
  portfolioId       String?
  anchor            String?
  scope             String?
  actor             String?

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("sibling_links")
}
