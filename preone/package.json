{
  "name": "preone",
  "version": "1.0.0",
  "private": true,
  "description": "PreOne \u2014 Enterprise Preschool Operating System (Modular Monorepo)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@preone/api",
    "dev:web": "turbo run dev --filter=@preone/web",
    "dev:worker": "turbo run dev --filter=@preone/worker",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @preone/database exec prisma generate",
    "db:migrate:dev": "pnpm --filter @preone/database exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @preone/database exec prisma migrate deploy",
    "db:seed": "pnpm --filter @preone/database exec tsx prisma/seeds/index.ts",
    "db:studio": "pnpm --filter @preone/database exec prisma studio",
    "docker:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.dev.yml logs -f",
    "prepare": "husky install",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:storybook": "turbo run dev --filter=@preone/storybook",
    "build:ui": "turbo run build --filter=@preone/ui --filter=@preone/design-tokens --filter=@preone/core --filter=@preone/env --filter=@preone/config"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.10.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
