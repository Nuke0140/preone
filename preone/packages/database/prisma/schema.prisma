  TRANSFER_CERTIFICATE
  PREVIOUS_REPORT_CARD
  MEDICAL_CERTIFICATE
  PROOF_OF_ADDRESS
  CASTE_CERTIFICATE
  INCOME_CERTIFICATE
  PHOTO
  OTHER
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VERIFIED
  REJECTED
  EXPIRED
}

enum StudentNoteType {
  ACADEMIC
  BEHAVIORAL
  HEALTH
  GENERAL
  INCIDENT
  ACHIEVEMENT
}

enum StudentFlagSeverity {
  INFO
  WARNING
  ALERT
}

enum StudentActivityAction {
  CREATED
  UPDATED
  ENROLLED
  PROMOTED
  TRANSFERRED
  WITHDRAWN
  REACTIVATED
  STATUS_CHANGED
  GUARDIAN_ADDED
  GUARDIAN_REMOVED
  DOCUMENT_UPLOADED
