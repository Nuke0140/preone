    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^9.4.0",
    "pino-http": "^10.5.0",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^11.2.2",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.2",
