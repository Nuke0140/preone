  createdAt      DateTime  @default(now())
  createdBy      String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  deletedAt      DateTime?
  deletedBy      String?
  version        Int       @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("driver_documents")
}

// MODEL: trip_logs (per ERD v3.0, aggregate=Transport)
model TripLog {
  id             String    @id @default(uuid())
  schoolId       String
  branchId       String?
  tripId         String
  loggedAt       DateTime
  latitude       Decimal
  longitude      Decimal
  speedKmph      Decimal?
  headingDegrees Int?
  eventType      String?
  stopId         String?
  studentId      String?
  notes          String?
  createdAt      DateTime  @default(now())
  createdBy      String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  deletedAt      DateTime?
  deletedBy      String?
  version        Int       @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("trip_logs")
}

// MODEL: transport_fees (per ERD v3.0, aggregate=Transport)
model TransportFee {
  id                  String           @id @default(uuid())
  schoolId            String
  branchId            String?
  studentId           String
  routeId             String
  academicSessionId   String
  annualFeeCents      Int
  paymentFrequency    FeeHeadFrequency
  perInstallmentCents Int
  isActive            Boolean
  createdAt           DateTime         @default(now())
  createdBy           String?
  updatedAt           DateTime         @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  version             Int              @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("transport_fees")
}

// MODEL: pickup_authorization_transports (per ERD v3.0, aggregate=Transport)
model PickupAuthorizationTransport {
  id                   String    @id @default(uuid())
  schoolId             String
  branchId             String?
  studentId            String
  routeId              String
  authorizedPersonName String
  relationship         String
  phone                String?
  photoUrl             String?
  grantedByGuardianId  String
  isActive             Boolean
  createdAt            DateTime  @default(now())
  createdBy            String?
  updatedAt            DateTime  @updatedAt
  updatedBy            String?
  deletedAt            DateTime?
  deletedBy            String?
  version              Int       @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("pickup_authorization_transports")
}

// MODEL: transport_route_alternates (per ERD v3.0, aggregate=Transport)
model TransportRouteAlternate {
  id                  String    @id @default(uuid())
  schoolId            String
  branchId            String?
  primaryRouteId      String
  alternateRouteId    String
  priority            Int
  createdAt           DateTime  @default(now())
  createdBy           String?
  updatedAt           DateTime  @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  version             Int       @default(1)
  academicSessionId   String?
  academicCalendarId  String?
  integrationConfigId String?
  anchor              String?
  scope               String?
  actor               String?

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("transport_route_alternates")
}

