model StaffRoleAssignment {
  id                   String    @id @default(uuid())
  schoolId             String
  branchId             String?
  staffId              String
  role                 String
  classroomId          String?
  academicSessionId    String?
  isPrimary            Boolean
  createdAt            DateTime  @default(now())
  createdBy            String?
  updatedAt            DateTime  @updatedAt
  updatedBy            String?
  deletedAt            DateTime?
  deletedBy            String?
  version              Int       @default(1)
  roomId               String?
  categoryId           String?
  assetId              String?
  maintenanceRequestId String?
  anchor               String?
  scope                String?
  actor                String?

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("staff_role_assignments")
}
