// MODEL: transfers (per ERD v3.0, aggregate=Student)
model Transfer {
  id                     String         @id @default(uuid())
  schoolId               String
  branchId               String?
  studentId              String
  transferType           String
  fromBranchId           String
  toBranchId             String?
  toSchoolName           String?
