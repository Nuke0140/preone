  documentNumber String?
  issuedDate     DateTime?
  expiryDate     DateTime?
  fileUrl        String
  verified       Boolean
  createdAt      DateTime  @default(now())
  createdBy      String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  deletedAt      DateTime?
  deletedBy      String?
  version        Int       @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("vehicle_documents")
}

// MODEL: driver_documents (per ERD v3.0, aggregate=Transport)
model DriverDocument {
  id             String    @id @default(uuid())
  schoolId       String
  branchId       String?
  driverId       String
  documentType   String
  documentNumber String?
  issuedDate     DateTime?
  expiryDate     DateTime?
  fileUrl        String
