{
  "name": "@preone/config",
  "version": "1.0.0",
  "private": true,
  "description": "Shared configuration for PreOne monorepo (TypeScript, ESLint, Tailwind, etc.)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tailwind": "./src/tailwind-preset.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
