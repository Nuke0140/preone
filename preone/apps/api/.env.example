# ─────────────────────────────────────────────────────────────
# PreOne API — Environment Variables (EXAMPLE TEMPLATE)
# ─────────────────────────────────────────────────────────────
# This file is safe to commit — contains only placeholders and
# non-sensitive local-dev defaults. Copy to `.env` (or `.env.local`)
# and fill in real values for local development.
#
# ⚠️  NEVER commit a real `.env` file. See `.gitignore`.
# ⚠️  NEVER hardcode secrets in source files.
# ⚠️  For production, inject secrets via the runtime environment
#     (Kubernetes secrets, AWS Secrets Manager, etc.) — never via
#     a committed file.
#
# Validation: see `apps/api/src/config/env/env.validator.ts`
# (Zod schema). Missing required vars will fail-fast at startup.
# ─────────────────────────────────────────────────────────────

# ═════════════════════════════════════════════════════════════
# APP
# ═════════════════════════════════════════════════════════════
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
RATE_LIMIT_PER_MINUTE=100
LOKI_HOST=http://localhost:3100
BODY_LIMIT=50mb

# ─────────────────────────────────────────────
# JWT — RSA keypair for access tokens, HMAC secret for refresh tokens
#
# Generate keys locally:
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#
# Then paste the PEM contents as single-line values (use \n escapes):
#   JWT_ACCESS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
#   JWT_ACCESS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"
#
# SECURITY: The app FAILS-FAST at startup if JWT_ACCESS_PRIVATE_KEY,
# JWT_ACCESS_PUBLIC_KEY, or JWT_REFRESH_SECRET are missing, too short,
# or set to a known-weak placeholder. No fallback secrets are used.
# ─────────────────────────────────────────────
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=30d
JWT_ISSUER=preone.api
JWT_AUDIENCE=preone.app
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
# Generate a strong random string (min 32 chars, no known-weak placeholders):
#   openssl rand -hex 32
JWT_REFRESH_SECRET=

# ─────────────────────────────────────────────
# PII ENCRYPTION KEY — pgcrypto symmetric key for encrypted columns
# (Aadhaar, PAN, bank details, etc. — see ERD v3.0 §7.3)
#
# Required in production. Optional in non-production — if unset,
# PrismaService falls back to a documented dev-only key with a warning.
# Generate: openssl rand -hex 32
# ─────────────────────────────────────────────
PII_ENCRYPTION_KEY=

BODY_LIMIT=50mb

# ═════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL 16
# Local dev default uses the docker-compose.dev.yml credentials.
# ═════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://preone:preone@localhost:5432/preone?schema=public
DATABASE_READ_REPLICA_URL=
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30000
DATABASE_STATEMENT_TIMEOUT=5000

# ═════════════════════════════════════════════════════════════
# REDIS — 7.2
# ═════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_NODES=
REDIS_SENTINEL_PASSWORD=
REDIS_KEY_PREFIX=preone:

# ═════════════════════════════════════════════════════════════
# S3 / Object Storage
# Local dev: MinIO (S3-compatible) via docker-compose.dev.yml
#   S3_ENDPOINT=http://localhost:9000
#   S3_FORCE_PATH_STYLE=true
# Prod: leave S3_ENDPOINT empty to use AWS S3 defaults
# ═════════════════════════════════════════════════════════════
AWS_REGION=ap-south-1
S3_BUCKET=preone-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PRESIGN_EXPIRY=3600

# ═════════════════════════════════════════════════════════════
# BULLMQ — background job queue (uses Redis)
# ═════════════════════════════════════════════════════════════
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3
BULLMQ_BACKOFF_TYPE=exponential
BULLMQ_BACKOFF_DELAY=1000

# ═════════════════════════════════════════════════════════════
# OTP — One-Time Password (SMS-based 2FA)
# ═════════════════════════════════════════════════════════════
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# ═════════════════════════════════════════════════════════════
# MSG91 — SMS via DLT-approved sender (India)
# Optional in dev; required in production for SMS delivery.
# ═════════════════════════════════════════════════════════════
MSG91_API_KEY=
MSG91_SENDER_ID=PREONE
MSG91_TEMPLATE_ID=

# ═════════════════════════════════════════════════════════════
# WhatsApp Cloud API (Meta Business)
# Optional in dev; required in production for WhatsApp messaging.
# ═════════════════════════════════════════════════════════════
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ═════════════════════════════════════════════════════════════
# Razorpay — Payments
# Optional in dev; required in production for payment processing.
# ═════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ═════════════════════════════════════════════════════════════
# OpenTelemetry — distributed tracing
# Local dev: set OTEL_ENABLED=false to disable.
# Prod: set OTEL_ENABLED=true and point to your OTLP collector.
# ═════════════════════════════════════════════════════════════
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=preone-api
OTEL_TRACES_SAMPLER_RATIO=1.0

# ═════════════════════════════════════════════════════════════
# CI/CD Secrets — NOT used by the app at runtime, but required by
# `.github/workflows/ci.yml`. Documented here for ops visibility.
# Configure these in GitHub repo Settings → Secrets and variables → Actions.
# ═════════════════════════════════════════════════════════════
# SNYK_TOKEN          — Snyk API token for dependency vuln scanning
# CODECOV_TOKEN       — Codecov upload token for coverage reports
# AWS_ACCESS_KEY_ID   — AWS IAM access key for ECR/EKS deploys (CI)
# AWS_SECRET_ACCESS_KEY — AWS IAM secret key (CI)
# ECR_REGISTRY        — ECR registry URL, e.g. <account>.dkr.ecr.ap-south-1.amazonaws.com
