{
  "name": "@preone/core",
  "version": "1.0.0",
  "private": true,
  "description": "Core utilities, types, and shared primitives for the PreOne platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./utils/string": "./src/utils/string.ts",
    "./utils/array": "./src/utils/array.ts",
    "./utils/object": "./src/utils/object.ts",
    "./utils/async": "./src/utils/async.ts",
    "./logger": "./src/logger/index.ts",
    "./events": "./src/events/index.ts",
    "./errors": "./src/errors/index.ts",
    "./cn": "./src/cn.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@preone/env": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.2"
  }
}
