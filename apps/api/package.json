    "@opentelemetry/sdk-metrics": "^1.26.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@prisma/client": "^6.0.0",
    "argon2": "^0.41.1",
    "axios": "^1.7.7",
    "bullmq": "^5.12.0",
    "casbin": "^5.27.1",
    "casbin-redis-adapter": "^1.0.4",
    "class-transformer": "^0.5.1",
