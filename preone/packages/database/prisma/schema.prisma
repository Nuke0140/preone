// PreOne Prisma Schema v3.0 — Multi-File (Wave 14)
// =================================================
// Database: PostgreSQL 16 (HA via Patroni + 2 read replicas)
// Multi-tenancy: Shared schema with school_id discriminator + RLS
//
// Scope (per ERD v3.0):
//   14 domains + Cross-Cutting + Platform Management = 15 domains
//   307+ tables • 215 enums • 412+ FKs
//
// ┌───────────────────────────────────────────────────────────────────────────┐
// │  MULTI-FILE SCHEMA (preview feature: prismaSchemaFolder)                  │
// │                                                                           │
// │  This root schema.prisma contains ONLY the generator + datasource blocks. │
// │  All model and enum definitions live in the ./schema/ subdirectory, one   │
// │  file per domain. Prisma merges them automatically at generate/validate   │
// │  time because the prismaSchemaFolder preview feature is enabled.          │
// │                                                                           │
// │  Domain files (under prisma/schema/):                                     │
// │    platform.prisma        — subscriptions, billing, integrations          │
// │    identity.prisma        — schools, branches, users, roles, permissions  │
// │    student.prisma         — students, guardians, medical, transfers       │
// │    academics.prisma       — sessions, curriculum, assessments, reports    │
// │    admissions.prisma      — applications, waiting lists, admissions       │
// │    attendance.prisma      — daily logs, reports, incidents                │
// │    communication.prisma   — notifications, announcements, chat            │
// │    finance.prisma         — fees, invoices, payments, refunds, GST        │
// │    hr.prisma              — employees, payroll, leaves, compliance        │
// │    crm.prisma             — leads, campaigns, follow-ups                  │
// │    inventory.prisma       — items, suppliers, POs, GRNs, audits           │
// │    administration.prisma  — assets, visitors, CCTV, maintenance           │
// │    transport.prisma       — vehicles, routes, trips, stops                │
// │    settings.prisma        — system config, calendar, preferences          │
// │    reports.prisma         — report definitions, executions                │
// │    cross_cutting.prisma   — audit log, outbox, attachments, shared enums  │
// │                                                                           │
// │  To re-split or modify the layout, edit /home/z/my-project/scripts/       │
// │  wave14_split_schema.py and re-run it (it reads from a single-file backup)│
// └───────────────────────────────────────────────────────────────────────────┘
//
// Naming conventions (per ERD v3.0 §3):
//   - Tables: snake_case plural (students, audit_log)
//   - Columns: snake_case (school_id, created_at)
//   - FKs: <entity>_id suffix
//   - Indexes: <table>_<columns>_idx (or _uidx for unique, _p for partial)
//   - Enums: PascalCase singular type (AttendanceStatus); values UPPER_SNAKE
//   - PKs: UUID v7 (time-sortable)
//   - Timestamps: timestamptz (with timezone) — never plain timestamp
//   - Money: integer cents (amount_cents) — never float
//   - Soft delete: deleted_at timestamptz NULL

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"]
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}
