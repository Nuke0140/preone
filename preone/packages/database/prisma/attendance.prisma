// PreOne Prisma Schema — Attendance domain
// Attendance & Daily Operations — daily logs, reports, incidents, meals, naps, toilet, mood, water intake
// Part of the multi-file Prisma schema (preview feature: prismaSchemaFolder).
// Do not edit generator/datasource here — those live in the root schema.prisma.

// Back-relations on existing models (Admissions)
// School gains admission-related relations
// Branch gains admission-related relations
// AcademicSession gains admission-related relations
// Student gains admission back-relation
// Classroom gains admission back-relation
// =============================================================================
// Wave 4 — Attendance / Daily Operations Domain (ERD v3.0 §16, trimmed)
// Tables implemented (20): attendance, attendance_bulk, attendance_correction,
//   arrival_log, pickup_log, late_pickup, late_arrival, early_departure,
//   meal_log, nap_log, toilet_log, mood_log, water_intake_log,
//   medicine_log, medicine_authorization, incident_report, incident_action,
//   daily_report, attendance_summary, daily_report_template
// Deferred to Wave 4.1: emergency_log, emergency_drill, today_dashboard,
//   time_slot, activity_schedule, visitor_log, visitor_blacklist, gate_pass,
//   field_trip, field_trip_authorization, meal_menu
// =============================================================================
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum ArrivalMode {
  WALK_IN
  CAR
  BUS
  AUTO
  OTHER
}

enum PickupMode {
  WALK_IN
  CAR
  BUS
  AUTO
  AFTER_SCHOOL
  OTHER
}

enum AttendanceSource {
  MANUAL
  BIOMETRIC
  RFID
  APP
}

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  AFTERNOON_SNACK
  DINNER
}

enum MealRating {
  ATE_WELL
  ATE_SOME
  ATE_LITTLE
  REFUSED
  NOT_SERVED
}

enum NapQuality {
  SLEPT_WELL
  RESTLESS
  DID_NOT_SLEEP
  SHORT_NAP
}

enum MoodRating {
  HAPPY
  CALM
  NEUTRAL
  TIRED
  UPSET
  AGGRESSIVE
  SICK
}

enum IncidentType {
  INJURY
  BITE
  FALL
  ALLERGIC_REACTION
  BEHAVIOR
  ILLNESS
  LOST_FOUND
  PROPERTY_DAMAGE
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  REPORTED
  INVESTIGATING
  ACTION_PENDING
  RESOLVED
  CLOSED
}

enum MedicineRoute {
  ORAL
  TOPICAL
  INHALATION
  INJECTION
  OPHTHALMIC
  OTIC
  NASAL
  OTHER
}

model Attendance {
  id                String           @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId          String           @map("school_id") @db.Uuid
  studentId         String           @map("student_id") @db.Uuid
  classroomId       String           @map("classroom_id") @db.Uuid
  academicSessionId String           @map("academic_session_id") @db.Uuid
  attendanceDate    DateTime         @map("attendance_date") @db.Date
  status            AttendanceStatus
  checkInAt         DateTime?        @map("check_in_at") @db.Timestamptz
  checkOutAt        DateTime?        @map("check_out_at") @db.Timestamptz
  arrivalMode       ArrivalMode?     @map("arrival_mode")
  pickupMode        PickupMode?      @map("pickup_mode")
  pickupGuardianId  String?          @map("pickup_guardian_id") @db.Uuid
  markedBy          String?          @map("marked_by") @db.Uuid
  markedAt          DateTime         @map("marked_at") @db.Timestamptz
  notes             String?          @db.Text
  source            AttendanceSource @default(MANUAL)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  student         Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom       Classroom              @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  academicSession AcademicSession        @relation(fields: [academicSessionId], references: [id], onDelete: Restrict)
  school          School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  corrections     AttendanceCorrection[]
  arrivalLog      ArrivalLog?
  pickupLog       PickupLog?
  latePickup      LatePickup?
  lateArrival     LateArrival?
  earlyDeparture  EarlyDeparture?
  dailyLogs       DailyLog[]
  dailyReport     DailyReport?

  @@unique([studentId, attendanceDate])
  @@index([classroomId, attendanceDate])
  @@index([attendanceDate, status])
  @@index([academicSessionId, attendanceDate])
  @@map("attendances")
}

model AttendanceBulk {
  id                String           @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId          String           @map("school_id") @db.Uuid
  classroomId       String           @map("classroom_id") @db.Uuid
  academicSessionId String           @map("academic_session_id") @db.Uuid
  attendanceDate    DateTime         @map("attendance_date") @db.Date
  markedBy          String           @map("marked_by") @db.Uuid
  markedAt          DateTime         @map("marked_at") @db.Timestamptz
  totalStudents     Int              @map("total_students")
  presentCount      Int              @map("present_count")
  absentCount       Int              @map("absent_count")
  lateCount         Int              @map("late_count")
  leaveCount        Int              @map("leave_count")
  source            AttendanceSource @default(MANUAL)
  notes             String?          @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  classroom       Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Restrict)
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([classroomId, attendanceDate])
  @@map("attendance_bulk_logs")
}

model AttendanceCorrection {
  id           String           @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId     String           @map("school_id") @db.Uuid
  attendanceId String           @map("attendance_id") @db.Uuid
  correctedBy  String           @map("corrected_by") @db.Uuid
  approvedBy   String?          @map("approved_by") @db.Uuid
  fromStatus   AttendanceStatus @map("from_status")
  toStatus     AttendanceStatus @map("to_status")
  reason       String           @db.Text
  correctedAt  DateTime         @map("corrected_at") @db.Timestamptz
  approvedAt   DateTime?        @map("approved_at") @db.Timestamptz
  isApproved   Boolean          @default(false) @map("is_approved")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([attendanceId, correctedAt])
  @@map("attendance_corrections")
}

model ArrivalLog {
  id                  String      @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId            String      @map("school_id") @db.Uuid
  attendanceId        String      @unique @map("attendance_id") @db.Uuid
  studentId           String      @map("student_id") @db.Uuid
  droppedByGuardianId String?     @map("dropped_by_guardian_id") @db.Uuid
  arrivalAt           DateTime    @map("arrival_at") @db.Timestamptz
  arrivalMode         ArrivalMode @map("arrival_mode")
  gateId              String?     @map("gate_id") @db.Uuid
  recordedBy          String      @map("recorded_by") @db.Uuid
  isLate              Boolean     @default(false) @map("is_late")
  notes               String?     @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId, arrivalAt])
  @@map("arrival_logs")
}

model PickupLog {
  id                       String     @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId                 String     @map("school_id") @db.Uuid
  attendanceId             String     @unique @map("attendance_id") @db.Uuid
  studentId                String     @map("student_id") @db.Uuid
  pickedByGuardianId       String?    @map("picked_by_guardian_id") @db.Uuid
  pickedByAuthorizedPerson String?    @map("picked_by_authorized_person") @db.VarChar(160)
  pickupAt                 DateTime   @map("pickup_at") @db.Timestamptz
  pickupMode               PickupMode @map("pickup_mode")
  recordedBy               String     @map("recorded_by") @db.Uuid
  isLate                   Boolean    @default(false) @map("is_late")
  notes                    String?    @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId, pickupAt])
  @@map("pickup_logs")
}

model LatePickup {
  id                 String    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId           String    @map("school_id") @db.Uuid
  attendanceId       String    @unique @map("attendance_id") @db.Uuid
  studentId          String    @map("student_id") @db.Uuid
  pickupLogId        String?   @map("pickup_log_id") @db.Uuid
  scheduledPickup    DateTime  @map("scheduled_pickup") @db.Timestamptz
  actualPickup       DateTime  @map("actual_pickup") @db.Timestamptz
  delayMinutes       Int       @map("delay_minutes")
  invoiceId          String?   @map("invoice_id") @db.Uuid
  feeChargedCents    Int?      @map("fee_charged_cents")
  reason             String?   @db.Text
  guardianNotifiedAt DateTime? @map("guardian_notified_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId, actualPickup])
  @@map("late_pickups")
}

model LateArrival {
  id             String    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  attendanceId   String    @unique @map("attendance_id") @db.Uuid
  studentId      String    @map("student_id") @db.Uuid
  scheduledStart DateTime  @map("scheduled_start") @db.Timestamptz
  actualArrival  DateTime  @map("actual_arrival") @db.Timestamptz
  delayMinutes   Int       @map("delay_minutes")
  reason         String?   @db.Text
  notifiedAt     DateTime? @map("notified_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId, actualArrival])
  @@map("late_arrivals")
}

model EarlyDeparture {
  id              String   @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  attendanceId    String   @unique @map("attendance_id") @db.Uuid
  studentId       String   @map("student_id") @db.Uuid
  scheduledEnd    DateTime @map("scheduled_end") @db.Timestamptz
  actualDeparture DateTime @map("actual_departure") @db.Timestamptz
  earlyMinutes    Int      @map("early_minutes")
  reason          String?  @db.Text
  approvedBy      String?  @map("approved_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId, actualDeparture])
  @@map("early_departures")
}

model DailyLog {
  id           String   @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId     String   @map("school_id") @db.Uuid
  attendanceId String   @map("attendance_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  logType      String   @map("log_type") @db.VarChar(16) // MEAL / NAP / TOILET / MOOD / WATER / MEDICINE
  loggedAt     DateTime @map("logged_at") @db.Timestamptz
  recordedBy   String   @map("recorded_by") @db.Uuid
  payload      Json     @default("{}") // type-specific data
  notes        String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId, logType, loggedAt])
  @@index([attendanceId, logType])
  @@map("daily_logs")
}

model MedicineAuthorization {
  id                     String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId               String        @map("school_id") @db.Uuid
  studentId              String        @map("student_id") @db.Uuid
  authorizedByGuardianId String        @map("authorized_by_guardian_id") @db.Uuid
  medicineName           String        @map("medicine_name") @db.VarChar(160)
  dosage                 String        @db.VarChar(64)
  route                  MedicineRoute
  frequency              String        @db.VarChar(64)
  startAt                DateTime      @map("start_at") @db.Timestamptz
  endAt                  DateTime?     @map("end_at") @db.Timestamptz
  instructions           String?       @db.Text
  prescriptionUrl        String?       @map("prescription_url") @db.Text
  isVerified             Boolean       @default(false) @map("is_verified")
  verifiedBy             String?       @map("verified_by") @db.Uuid
  verifiedAt             DateTime?     @map("verified_at") @db.Timestamptz
  isActive               Boolean       @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId, isActive])
  @@map("medicine_authorizations")
}

model IncidentReport {
  id                 String           @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId           String           @map("school_id") @db.Uuid
  studentId          String           @map("student_id") @db.Uuid
  classroomId        String           @map("classroom_id") @db.Uuid
  incidentType       IncidentType     @map("incident_type")
  severity           IncidentSeverity
  status             IncidentStatus   @default(REPORTED)
  occurredAt         DateTime         @map("occurred_at") @db.Timestamptz
  reportedAt         DateTime         @map("reported_at") @db.Timestamptz
  reportedBy         String           @map("reported_by") @db.Uuid
  location           String?          @db.VarChar(160)
  description        String           @db.Text
  immediateAction    String?          @map("immediate_action") @db.Text
  guardianNotifiedAt DateTime?        @map("guardian_notified_at") @db.Timestamptz
  guardianNotifiedBy String?          @map("guardian_notified_by") @db.Uuid
  resolvedAt         DateTime?        @map("resolved_at") @db.Timestamptz
  resolutionNotes    String?          @map("resolution_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom Classroom        @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  school    School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actions   IncidentAction[]

  @@index([studentId, occurredAt])
  @@index([status, severity])
  @@index([classroomId, occurredAt])
  @@map("incident_reports")
}

model IncidentAction {
  id          String    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId    String    @map("school_id") @db.Uuid
  incidentId  String    @map("incident_id") @db.Uuid
  actionType  String    @map("action_type") @db.VarChar(64) // FIRST_AID / PARENT_CALL / MEDICAL / REPORT / OTHER
  description String    @db.Text
  performedBy String    @map("performed_by") @db.Uuid
  performedAt DateTime  @map("performed_at") @db.Timestamptz
  outcome     String?   @db.Text
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  incident IncidentReport @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  school   School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([incidentId, performedAt])
  @@map("incident_actions")
}

model DailyReport {
  id                String    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId          String    @map("school_id") @db.Uuid
  studentId         String    @map("student_id") @db.Uuid
  attendanceId      String    @unique @map("attendance_id") @db.Uuid
  classroomId       String    @map("classroom_id") @db.Uuid
  reportDate        DateTime  @map("report_date") @db.Date
  templateId        String?   @map("template_id") @db.Uuid
  summary           String?   @db.Text
  moodSummary       String?   @map("mood_summary") @db.Text
  mealsSummary      String?   @map("meals_summary") @db.Text
  activitiesSummary String?   @map("activities_summary") @db.Text
  napSummary        String?   @map("nap_summary") @db.Text
  toiletSummary     String?   @map("toilet_summary") @db.Text
  highlights        Json      @default("[]")
  teacherNotes      String?   @map("teacher_notes") @db.Text
  generatedAt       DateTime  @map("generated_at") @db.Timestamptz
  generatedBy       String?   @map("generated_by") @db.Uuid
  sentToParentAt    DateTime? @map("sent_to_parent_at") @db.Timestamptz
  parentAckAt       DateTime? @map("parent_ack_at") @db.Timestamptz
  status            String    @default("DRAFT") @db.VarChar(16) // DRAFT / GENERATED / SENT / ACKNOWLEDGED

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  classroom  Classroom  @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, reportDate])
  @@map("daily_reports")
}

model DailyReportTemplate {
  id       String  @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String  @map("school_id") @db.Uuid
  branchId String? @map("branch_id") @db.Uuid
  name     String  @db.VarChar(160)
  sections Json    @default("[]")
  branding Json    @default("{}")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([schoolId, isActive])
  @@map("daily_report_templates")
}

model AttendanceSummary {
  id                String   @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId          String   @map("school_id") @db.Uuid
  studentId         String   @map("student_id") @db.Uuid
  academicSessionId String   @map("academic_session_id") @db.Uuid
  monthYear         DateTime @map("month_year") @db.Date // first day of month
  totalWorkingDays  Int      @map("total_working_days")
  presentDays       Int      @map("present_days")
  absentDays        Int      @map("absent_days")
  lateDays          Int      @map("late_days")
  halfDays          Int      @map("half_days")
  leaveDays         Int      @map("leave_days")
  attendancePercent Decimal  @map("attendance_percent") @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicSessionId, monthYear])
  @@map("attendance_summaries")
}

// MODEL: meal_logs (per ERD v3.0, aggregate=Attendance)
model MealLog {
  id          String          @id @default(uuid())
  schoolId    String
  branchId    String?
  studentId   String
  mealDate    DateTime
  mealType    MealType
  menuItem    String?
  amountEaten MealAmountEaten
  notes       String?
  recordedBy  String?
  createdAt   DateTime        @default(now())
  createdBy   String?
  updatedAt   DateTime        @updatedAt
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?
  version     Int             @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("meal_logs")
}

// MODEL: meal_menus (per ERD v3.0, aggregate=Attendance)
model MealMenu {
  id        String    @id @default(uuid())
  schoolId  String
  branchId  String?
  menuDate  DateTime
  mealType  MealType
  menuItems Json
  notes     String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?
  version   Int       @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("meal_menus")
}

// MODEL: nap_logs (per ERD v3.0, aggregate=Attendance)
model NapLog {
  id              String     @id @default(uuid())
  schoolId        String
  branchId        String?
  studentId       String
  napDate         DateTime
  napStartAt      DateTime?
  napEndAt        DateTime?
  durationMinutes Int?
  quality         NapQuality
  notes           String?
  createdAt       DateTime   @default(now())
  createdBy       String?
  updatedAt       DateTime   @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?
  version         Int        @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("nap_logs")
}

// MODEL: toilet_logs (per ERD v3.0, aggregate=Attendance)
model ToiletLog {
  id         String     @id @default(uuid())
  schoolId   String
  branchId   String?
  studentId  String
  logDate    DateTime
