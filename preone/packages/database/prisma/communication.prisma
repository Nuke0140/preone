// PreOne Prisma Schema — Communication domain
// Communication — templates, notifications, announcements, chat, provider delivery logs
// Part of the multi-file Prisma schema (preview feature: prismaSchemaFolder).
// Do not edit generator/datasource here — those live in the root schema.prisma.

// ═════════════════════════════════════════════════════════════════
// WAVE 5 — COMMUNICATION MODULE (BTD §4.3 #7)
// Announcements, Chat, Notifications — ~50 APIs
// ═════════════════════════════════════════════════════════════════
enum NotificationChannel {
  SMS
  EMAIL
  PUSH
  WHATSAPP
  IN_APP
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum NotificationStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

enum AnnouncementAudience {
  ALL_SCHOOL
  BRANCH
  CLASSROOM
  GRADE_LEVEL
  STAFF_ONLY
  PARENTS_ONLY
  SPECIFIC_USERS
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ConversationType {
  DIRECT
  GROUP
  CLASSROOM
  BROADCAST
}

enum ConversationParticipantRole {
  MEMBER
  ADMIN
  OWNER
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
  RECALLED
}

enum CommunicationProviderType {
  SMS_GUPSHUP
  SMS_MSG91
  EMAIL_SES
  EMAIL_SENDGRID
  PUSH_FCM
  PUSH_APNS
  WHATSAPP_GUPSHUP
  WHATSAPP_INTERAKT
}

enum CommunicationTemplateType {
  NOTIFICATION
  ANNOUNCEMENT
  TRANSACTIONAL
  MARKETING
  OTP
  RECEIPT
}

enum DeliveryLogStatus {
  ACCEPTED
  SENT
  DELIVERED
  FAILED
  REJECTED
  BOUNCED
}

enum CommTriggerEvent {
  ADMISSION_APPROVED
  ADMISSION_CANCELLED
  APPLICATION_SUBMITTED
  APPLICATION_REJECTED
  SEAT_OFFERED
  ATTENDANCE_MARKED
  INCIDENT_REPORTED
  DAILY_REPORT_SENT
  LATE_PICKUP
  FEE_INVOICE_GENERATED
  FEE_PAYMENT_RECEIVED
  FEE_REFUND_PROCESSED
  FEE_LATE_FEE_CHARGED
  MANUAL
}

// ─── Communication: Templates ───
model CommunicationTemplate {
  id           String                    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId     String                    @map("school_id") @db.Uuid
  branchId     String?                   @map("branch_id") @db.Uuid
  templateCode String                    @map("template_code") @db.VarChar(64)
  name         String                    @db.VarChar(160)
  channel      NotificationChannel
  type         CommunicationTemplateType @default(TRANSACTIONAL)
  triggerEvent CommTriggerEvent?         @map("trigger_event")
  locale       String                    @default("en-IN") @db.VarChar(16)

  subject            String? @db.VarChar(255)
  body               String  @db.Text
  variablesSchema    Json    @default("{}") @map("variables_schema")
  providerTemplateId String? @map("provider_template_id") @db.VarChar(128)
  isApproved         Boolean @default(false) @map("is_approved")
  isActive           Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id])
  notifications Notification[]

  @@unique([schoolId, templateCode, channel, locale])
  @@index([triggerEvent, channel])
  @@index([schoolId, isActive])
  @@map("communication_templates")
}

// ─── Communication: Notifications ───
model Notification {
  id                  String               @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId            String               @map("school_id") @db.Uuid
  branchId            String?              @map("branch_id") @db.Uuid
  templateId          String?              @map("template_id") @db.Uuid
  triggerEvent        CommTriggerEvent?    @map("trigger_event")
  sourceAggregateType String?              @map("source_aggregate_type") @db.VarChar(40)
  sourceAggregateId   String?              @map("source_aggregate_id") @db.Uuid
  channel             NotificationChannel
  priority            NotificationPriority @default(NORMAL)
  subject             String?              @db.VarChar(255)
  body                String               @db.Text
  variables           Json                 @default("{}")
  scheduledAt         DateTime?            @map("scheduled_at") @db.Timestamptz
  sentAt              DateTime?            @map("sent_at") @db.Timestamptz
  status              NotificationStatus   @default(QUEUED)
  failureReason       String?              @map("failure_reason") @db.Text
  retryCount          Int                  @default(0) @map("retry_count")
  maxRetries          Int                  @default(3) @map("max_retries")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school                    School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch                    Branch?                    @relation(fields: [branchId], references: [id])
  template                  CommunicationTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients                NotificationRecipient[]
  communicationDeliveryLogs CommunicationDeliveryLog[]

  @@index([status, scheduledAt])
  @@index([triggerEvent, status])
  @@index([schoolId, channel, status])
  @@index([sourceAggregateType, sourceAggregateId])
  @@map("notifications")
}

model NotificationRecipient {
  id                   String             @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId             String             @map("school_id") @db.Uuid
  notificationId       String             @map("notification_id") @db.Uuid
  userId               String?            @map("user_id") @db.Uuid
  studentId            String?            @map("student_id") @db.Uuid
  guardianId           String?            @map("guardian_id") @db.Uuid
  recipientName        String?            @map("recipient_name") @db.VarChar(160)
  recipientEmail       String?            @map("recipient_email") @db.Citext
  recipientPhone       String?            @map("recipient_phone") @db.VarChar(16)
  recipientDeviceToken String?            @map("recipient_device_token") @db.VarChar(255)
  status               NotificationStatus @default(QUEUED)
  providerMessageId    String?            @map("provider_message_id") @db.VarChar(128)
  sentAt               DateTime?          @map("sent_at") @db.Timestamptz
  deliveredAt          DateTime?          @map("delivered_at") @db.Timestamptz
  readAt               DateTime?          @map("read_at") @db.Timestamptz
  failureReason        String?            @map("failure_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  student      Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  guardian     Guardian?    @relation(fields: [guardianId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([userId, status])
  @@index([guardianId])
  @@map("notification_recipients")
}

// ─── Communication: Announcements ───
model Announcement {
  id                      String               @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId                String               @map("school_id") @db.Uuid
  branchId                String?              @map("branch_id") @db.Uuid
  classroomId             String?              @map("classroom_id") @db.Uuid
  title                   String               @db.VarChar(255)
  body                    String               @db.Text
  audience                AnnouncementAudience
  status                  AnnouncementStatus   @default(DRAFT)
  priority                NotificationPriority @default(NORMAL)
  attachments             Json                 @default("[]")
  authorId                String               @map("author_id") @db.Uuid
  publishedAt             DateTime?            @map("published_at") @db.Timestamptz
  scheduledAt             DateTime?            @map("scheduled_at") @db.Timestamptz
  expiresAt               DateTime?            @map("expires_at") @db.Timestamptz
  acknowledgementRequired Boolean              @default(false) @map("acknowledgement_required")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school     School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch     Branch?                 @relation(fields: [branchId], references: [id])
  classroom  Classroom?              @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  recipients AnnouncementRecipient[]

  @@index([schoolId, status, publishedAt])
  @@index([branchId, status])
  @@index([audience, status])
  @@map("announcements")
}

model AnnouncementRecipient {
  id                  String    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId            String    @map("school_id") @db.Uuid
  announcementId      String    @map("announcement_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  guardianId          String?   @map("guardian_id") @db.Uuid
  studentId           String?   @map("student_id") @db.Uuid
  deliveredAt         DateTime? @map("delivered_at") @db.Timestamptz
  readAt              DateTime? @map("read_at") @db.Timestamptz
  acknowledgedAt      DateTime? @map("acknowledged_at") @db.Timestamptz
  acknowledgementNote String?   @map("acknowledgement_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guardian     Guardian?    @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  student      Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([announcementId, userId])
  @@index([userId, readAt])
  @@map("announcement_recipients")
}

// ─── Communication: Chat ───
model Conversation {
  id                 String           @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId           String           @map("school_id") @db.Uuid
  branchId           String?          @map("branch_id") @db.Uuid
  classroomId        String?          @map("classroom_id") @db.Uuid
  type               ConversationType
  title              String?          @db.VarChar(160)
  avatarUrl          String?          @map("avatar_url") @db.VarChar(512)
  lastMessageAt      DateTime         @map("last_message_at") @db.Timestamptz
  lastMessagePreview String?          @map("last_message_preview") @db.VarChar(255)
  isActive           Boolean          @default(true) @map("is_active")
  createdBy          String           @map("created_by") @db.Uuid
  metadata           Json             @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school       School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch       Branch?                   @relation(fields: [branchId], references: [id])
  classroom    Classroom?                @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([schoolId, isActive])
  @@index([classroomId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id                String                      @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId          String                      @map("school_id") @db.Uuid
  conversationId    String                      @map("conversation_id") @db.Uuid
  userId            String                      @map("user_id") @db.Uuid
  role              ConversationParticipantRole @default(MEMBER)
  lastReadAt        DateTime?                   @map("last_read_at") @db.Timestamptz
  lastReadMessageId String?                     @map("last_read_message_id") @db.Uuid
  mutedUntil        DateTime?                   @map("muted_until") @db.Timestamptz
  isActive          Boolean                     @default(true) @map("is_active")
  joinedAt          DateTime                    @default(now()) @map("joined_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, isActive])
  @@map("conversation_participants")
}

model Message {
  id             String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId       String        @map("school_id") @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  senderId       String        @map("sender_id") @db.Uuid
  body           String        @db.Text
  attachments    Json          @default("[]")
  replyToId      String?       @map("reply_to_id") @db.Uuid
  status         MessageStatus @default(SENT)
  editedAt       DateTime?     @map("edited_at") @db.Timestamptz
  recalledAt     DateTime?     @map("recalled_at") @db.Timestamptz
  metadata       Json          @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  conversation Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  school       School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender       User                 @relation(fields: [senderId], references: [id], onDelete: Restrict)
  replyTo      Message?             @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]            @relation("MessageReply")
  readReceipts MessageReadReceipt[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model MessageReadReceipt {
  id        String   @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @map("read_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_read_receipts")
}

// ─── Communication: Provider + Delivery logs ───
model CommunicationProviderConfig {
  id              String                    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String                    @map("school_id") @db.Uuid
  providerType    CommunicationProviderType
  displayName     String                    @map("display_name") @db.VarChar(120)
  apiKey          String                    @map("api_key") @db.Text // PII-encrypted via pii_encrypt
  apiSecret       String?                   @map("api_secret") @db.Text // PII-encrypted
  senderId        String?                   @map("sender_id") @db.VarChar(64)
  webhookUrl      String?                   @map("webhook_url") @db.VarChar(512)
  webhookSecret   String?                   @map("webhook_secret") @db.VarChar(255)
  dailyQuotaSms   Int                       @default(0) @map("daily_quota_sms")
  dailyQuotaEmail Int                       @default(0) @map("daily_quota_email")
  isPrimary       Boolean                   @default(false) @map("is_primary")
  isActive        Boolean                   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, providerType])
  @@index([schoolId, isActive])
  @@map("communication_provider_configs")
}

model CommunicationDeliveryLog {
  id                String                    @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId          String                    @map("school_id") @db.Uuid
  notificationId    String?                   @map("notification_id") @db.Uuid
  recipientId       String?                   @map("recipient_id") @db.Uuid
  providerType      CommunicationProviderType
  providerMessageId String?                   @map("provider_message_id") @db.VarChar(128)
  channel           NotificationChannel
  status            DeliveryLogStatus
  errorCode         String?                   @map("error_code") @db.VarChar(64)
  errorMessage      String?                   @map("error_message") @db.Text
  providerResponse  Json                      @default("{}") @map("provider_response")
  attemptedAt       DateTime                  @map("attempted_at") @db.Timestamptz
  deliveredAt       DateTime?                 @map("delivered_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([providerType, status])
  @@index([schoolId, attemptedAt])
  @@map("communication_delivery_logs")
}

