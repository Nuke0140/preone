// ─────────────────────────────────────────────
// MODELS — Student Lifecycle (22 tables, per ERD §14)
// ─────────────────────────────────────────────

model Student {
  id       String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid
  branchId String @map("branch_id") @db.Uuid

  admissionNumber        String     @unique @map("admission_number") @db.VarChar(32)
  // ENCRYPTED — birth certificate name as per government records
  legalFirstName         String     @map("legal_first_name") @db.VarChar(80)
  legalLastName          String     @map("legal_last_name") @db.VarChar(80)
  preferredName          String?    @map("preferred_name") @db.VarChar(80)
  // ENCRYPTED — DOB stored as ISO date string; only reveal via service layer
  dateOfBirth            DateTime   @map("date_of_birth") @db.Date
  gender                 Gender     @default(UNSPECIFIED)
  bloodGroup             BloodGroup @default(UNKNOWN)
  nationality            String     @default("Indian") @db.VarChar(60)
  religion               String?    @db.VarChar(60)
  motherTongue           String?    @map("mother_tongue") @db.VarChar(60)
  // ENCRYPTED — PII
  aadhaarNumber          String?    @map("aadhaar_number") @db.VarChar(255) // pgcrypto-encrypted
  // ENCRYPTED — PII
  birthCertificateNumber String?    @map("birth_certificate_number") @db.VarChar(255)
  placeOfBirth           String?    @map("place_of_birth") @db.VarChar(120)
  photoUrl               String?    @map("photo_url") @db.VarChar(512)

  status     StudentStatus @default(PROSPECT)
  admittedAt DateTime      @map("admitted_at") @db.Timestamptz
  // set when student becomes ACTIVE in a section
  enrolledAt DateTime?     @map("enrolled_at") @db.Timestamptz
  // set when student leaves (graduated/withdrawn/transferred)
  exitedAt   DateTime?     @map("exited_at") @db.Timestamptz
  exitReason String?       @map("exit_reason") @db.Text

  // Computed (denormalised) — kept in sync by aggregate
  ageMonths         Int     @default(0) @map("age_months")
  currentGradeLevel String? @map("current_grade_level") @db.VarChar(32)
  currentSectionId  String? @map("current_section_id") @db.Uuid

  allergiesSummary String? @map("allergies_summary") @db.Text
  medicalAlerts    Json?   @map("medical_alerts") // [{severity, summary}]
  custodyNotes     String? @map("custody_notes") @db.Text

  isPickupRestricted Boolean @default(false) @map("is_pickup_restricted")

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  school                School                  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  branch                Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  profile               StudentProfile?
  guardianLinks         StudentGuardian[]
  medicalRecords        MedicalRecord[]
  documents             StudentDocument[]
  photos                StudentPhoto[]
  enrollments           Enrollment[]
  notes                 StudentNote[]
  flags                 StudentFlag[]
  tagAssignments        StudentTagAssignment[]
  siblingLinksFrom      SiblingRelationship[]   @relation("sibling_from")
  siblingLinksTo        SiblingRelationship[]   @relation("sibling_to")
  statusHistory         StudentStatusHistory[]
  activityLog           StudentActivityLog[]
  pickupAuthorizations  PickupAuthorization[]
  medicalHistory        StudentMedicalHistory[]
  idCards               StudentIdCard[]
  milestoneAchievements MilestoneAchievement[]

  @@index([schoolId, branchId, status])
  @@index([branchId, currentSectionId])
  @@index([admissionNumber])
  @@index([status])
  @@map("students")
}

model StudentProfile {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @unique @map("student_id") @db.Uuid

  addressLine1 String? @map("address_line1") @db.VarChar(255)
  addressLine2 String? @map("address_line2") @db.VarChar(255)
  city         String? @db.VarChar(120)
  state        String? @db.VarChar(120)
  postalCode   String? @map("postal_code") @db.VarChar(16)
  country      String  @default("India") @db.VarChar(60)

  // Denormalised for fast lookup
  primaryGuardianName  String? @map("primary_guardian_name") @db.VarChar(160)
  primaryGuardianPhone String? @map("primary_guardian_phone") @db.VarChar(32)
  primaryGuardianEmail String? @map("primary_guardian_email") @db.VarChar(160)

  // Free-form bio
  dietaryRestrictions String? @map("dietary_restrictions") @db.Text
  likes               String? @db.Text
  dislikes            String? @db.Text
  hobbies             String? @db.Text
  strengths           String? @db.Text
  improvementAreas    String? @map("improvement_areas") @db.Text

  // Previous schooling
  previousSchool String? @map("previous_school") @db.VarChar(200)
  previousGrade  String? @map("previous_grade") @db.VarChar(60)
  transferReason String? @map("transfer_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model Guardian {
  id       String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid

  firstName         String  @map("first_name") @db.VarChar(80)
  lastName          String  @map("last_name") @db.VarChar(80)
  email             String? @db.VarChar(160)
  phone             String  @db.VarChar(32)
  altPhone          String? @map("alt_phone") @db.VarChar(32)
  occupation        String? @db.VarChar(120)
  employer          String? @db.VarChar(120)
  annualIncomeCents Int?    @map("annual_income_cents")
  education         String? @db.VarChar(120)
  // ENCRYPTED — government ID (PAN/Aadhaar)
  governmentId      String? @map("government_id") @db.VarChar(255)

  addressLine1 String? @map("address_line1") @db.VarChar(255)
  addressLine2 String? @map("address_line2") @db.VarChar(255)
  city         String? @db.VarChar(120)
  state        String? @db.VarChar(120)
  postalCode   String? @map("postal_code") @db.VarChar(16)

  status GuardianStatus @default(ACTIVE)

  // Linked user (if guardian has portal access)
  userId String? @unique @map("user_id") @db.Uuid

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  school       School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  studentLinks StudentGuardian[]
  users        User[]

  @@index([schoolId, phone])
  @@index([schoolId, email])
  @@index([userId])
  @@map("guardians")
}

model StudentGuardian {
  id         String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId  String @map("student_id") @db.Uuid
  guardianId String @map("guardian_id") @db.Uuid

  relation           GuardianRelation
  isPrimary          Boolean          @default(false) @map("is_primary")
  isPickupAuthorized Boolean          @default(true) @map("is_pickup_authorized")
  isEmergencyContact Boolean          @default(true) @map("is_emergency_contact")
  custodyHolder      Boolean          @default(false) @map("custody_holder")
  notes              String?          @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([studentId, isPrimary])
  @@index([guardianId])
  @@map("student_guardians")
}

model MedicalRecord {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  heightCm            Int?       @map("height_cm")
  weightKg            Int?       @map("weight_kg")
  bmi                 Float?
  bloodGroup          BloodGroup @default(UNKNOWN)
  // ENCRYPTED — medical conditions
  conditions          Json? // [{name, severity, notes}]
  medications         Json? // [{name, dose, schedule}]
  dietaryRestrictions String?    @map("dietary_restrictions") @db.Text
  // ENCRYPTED — doctor contact info
  primaryDoctorName   String?    @map("primary_doctor_name") @db.VarChar(160)
  primaryDoctorPhone  String?    @map("primary_doctor_phone") @db.VarChar(32)
  hospitalPreference  String?    @map("hospital_preference") @db.VarChar(200)

  insuranceProvider String? @map("insurance_provider") @db.VarChar(120)
  // ENCRYPTED
  insuranceNumber   String? @map("insurance_number") @db.VarChar(255)

  notes      String?  @db.Text
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  immunizations Immunization[]
  allergies     Allergy[]

  @@index([studentId])
  @@map("medical_records")
}

model Immunization {
  id              String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  medicalRecordId String @map("medical_record_id") @db.Uuid

  vaccineName    String   @map("vaccine_name") @db.VarChar(120)
  doseNumber     Int      @default(1) @map("dose_number")
  administeredAt DateTime @map("administered_at") @db.Date
  administeredBy String?  @map("administered_by") @db.VarChar(160)
  batchNumber    String?  @map("batch_number") @db.VarChar(60)
  // ENCRYPTED — certificate URL with signed token
  certificateUrl String?  @map("certificate_url") @db.VarChar(512)

  status ImmunizationStatus @default(COMPLETED)
  notes  String?            @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@index([vaccineName])
  @@map("immunizations")
}

model Allergy {
  id              String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  medicalRecordId String @map("medical_record_id") @db.Uuid

  allergen       String          @db.VarChar(120)
  severity       AllergySeverity @default(MILD)
  reaction       String?         @db.Text
  // First-aid protocol for teachers
  protocol       String?         @db.Text
  epipenRequired Boolean         @default(false) @map("epipen_required")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@index([allergen])
  @@map("allergies")
}

model StudentDocument {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  type           DocumentType
  title          String       @db.VarChar(160)
  documentNumber String?      @map("document_number") @db.VarChar(120)
  issuedBy       String?      @map("issued_by") @db.VarChar(160)
  issuedAt       DateTime?    @map("issued_at") @db.Date
  // S3 object key — service layer issues pre-signed URL
  s3ObjectKey    String       @map("s3_object_key") @db.VarChar(512)
  fileName       String       @map("file_name") @db.VarChar(255)
  mimeType       String       @map("mime_type") @db.VarChar(80)
  fileSizeBytes  Int          @map("file_size_bytes")
  checksum       String?      @db.VarChar(80)

  status          DocumentStatus @default(UPLOADED)
  verifiedAt      DateTime?      @map("verified_at") @db.Timestamptz
  verifiedBy      String?        @map("verified_by") @db.Uuid
  rejectionReason String?        @map("rejection_reason") @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, type])
  @@index([status])
  @@map("student_documents")
}

model StudentPhoto {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  type          String    @db.VarChar(32) // 'PROFILE', 'CLASSROOM', 'EVENT', 'PORTFOLIO'
  caption       String?   @db.VarChar(255)
  s3ObjectKey   String    @map("s3_object_key") @db.VarChar(512)
  fileName      String    @map("file_name") @db.VarChar(255)
  mimeType      String    @map("mime_type") @db.VarChar(80)
  fileSizeBytes Int       @map("file_size_bytes")
  widthPx       Int?      @map("width_px")
  heightPx      Int?      @map("height_px")
  takenAt       DateTime? @map("taken_at") @db.Timestamptz
  isPrimary     Boolean   @default(false) @map("is_primary")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, type])
  @@index([isPrimary])
  @@map("student_photos")
}

model StudentNote {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  type      StudentNoteType @default(GENERAL)
  note      String          @db.Text
  isPrivate Boolean         @default(true) @map("is_private") // hidden from parents
  isPinned  Boolean         @default(false) @map("is_pinned")

  createdBy String    @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, type])
  @@index([createdBy])
  @@map("student_notes")
}

model StudentFlag {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  code      String              @db.VarChar(60) // 'BEHAVIOR_ISSUE', 'MEDICAL_ALERT', 'CUSTODY_DISPUTE', etc.
  severity  StudentFlagSeverity @default(INFO)
  summary   String              @db.VarChar(255)
  details   String?             @db.Text
  isActive  Boolean             @default(true) @map("is_active")
  expiresAt DateTime?           @map("expires_at") @db.Timestamptz

  createdBy       String    @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz
  resolvedBy      String?   @map("resolved_by") @db.Uuid
  resolutionNotes String?   @map("resolution_notes") @db.Text

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, isActive])
  @@index([code])
  @@map("student_flags")
}

model StudentTag {
  id       String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid

  name        String  @db.VarChar(60)
  color       String  @default("#6b7280") @db.VarChar(9) // hex color
  description String? @db.Text
  isSystemTag Boolean @default(false) @map("is_system_tag")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  school      School                 @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  assignments StudentTagAssignment[]

  @@unique([schoolId, name])
  @@map("student_tags")
}

model StudentTagAssignment {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  assignedBy String    @map("assigned_by") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  removedAt  DateTime? @map("removed_at") @db.Timestamptz

  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tag     StudentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([studentId, tagId])
  @@index([tagId])
  @@map("student_tag_assignments")
}

model SiblingRelationship {
  id            String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  fromStudentId String @map("from_student_id") @db.Uuid
  toStudentId   String @map("to_student_id") @db.Uuid

  relationType    SiblingRelationType @default(SIBLING)
  sharedHousehold Boolean             @default(true) @map("shared_household")
  notes           String?             @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  fromStudent Student @relation("sibling_from", fields: [fromStudentId], references: [id], onDelete: Cascade)
  toStudent   Student @relation("sibling_to", fields: [toStudentId], references: [id], onDelete: Cascade)

  @@unique([fromStudentId, toStudentId])
  @@index([toStudentId])
  @@map("sibling_relationships")
}

model StudentStatusHistory {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  fromStatus StudentStatus
  toStatus   StudentStatus
  changedAt  DateTime      @map("changed_at") @db.Timestamptz
  reason     String?       @db.Text
  changedBy  String        @map("changed_by") @db.Uuid

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, changedAt])
  @@map("student_status_history")
}

model StudentActivityLog {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  action      StudentActivityAction
  description String                @db.Text
  metadata    Json?
  ipAddress   String?               @map("ip_address") @db.VarChar(45)
  userAgent   String?               @map("user_agent") @db.VarChar(255)

  actorId   String   @map("actor_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([action])
  @@index([actorId])
  @@map("student_activity_log")
}

model PickupAuthorization {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  // Either link a guardian OR an ad-hoc person
  guardianId     String? @map("guardian_id") @db.Uuid
  personName     String? @map("person_name") @db.VarChar(160)
  personPhone    String? @map("person_phone") @db.VarChar(32)
  personRelation String? @map("person_relation") @db.VarChar(60)
  photoUrl       String? @map("photo_url") @db.VarChar(512)
  idProofUrl     String? @map("id_proof_url") @db.VarChar(512)

  effectiveFrom  DateTime  @map("effective_from") @db.Timestamptz
  effectiveUntil DateTime? @map("effective_until") @db.Timestamptz
  isOneTime      Boolean   @default(false) @map("is_one_time")
  isUsed         Boolean   @default(false) @map("is_used")
  usedAt         DateTime? @map("used_at") @db.Timestamptz
  notes          String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, effectiveFrom])
  @@map("pickup_authorizations")
}

model StudentMedicalHistory {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  event            String               @db.VarChar(160) // 'FEVER', 'INJURY', 'ALLERGIC_REACTION', etc.
  description      String               @db.Text
  severity         MedicalAlertSeverity @default(INFO)
  occurredAt       DateTime             @map("occurred_at") @db.Timestamptz
  resolvedAt       DateTime?            @map("resolved_at") @db.Timestamptz
  treatment        String?              @db.Text
  // ENCRYPTED — doctor name
  attendingDoctor  String?              @map("attending_doctor") @db.VarChar(255)
  reportedBy       String               @map("reported_by") @db.Uuid
  followupRequired Boolean              @default(false) @map("followup_required")
  followupDate     DateTime?            @map("followup_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, occurredAt])
  @@index([severity])
  @@map("student_medical_history")
}

model StudentIdCard {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId String @map("student_id") @db.Uuid

  cardNumber   String    @unique @map("card_number") @db.VarChar(40)
  barcode      String?   @db.VarChar(80)
  qrPayload    String?   @map("qr_payload") @db.Text
  issuedAt     DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  isActive     Boolean   @default(true) @map("is_active")
  lostAt       DateTime? @map("lost_at") @db.Timestamptz
  replacedById String?   @map("replaced_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([isActive])
  @@map("student_id_cards")
}

// ─────────────────────────────────────────────
// MODELS — Academics (27 tables, per ERD §15)
// ─────────────────────────────────────────────

model AcademicSession {
  id       String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid

  name      String                @db.VarChar(80) // '2025-26'
  code      String                @db.VarChar(16) // 'AY2526'
  startDate DateTime              @map("start_date") @db.Date
  endDate   DateTime              @map("end_date") @db.Date
  status    AcademicSessionStatus @default(PLANNED)

  isFirstTerm Boolean   @default(false) @map("is_first_term")
  isCurrent   Boolean   @default(false) @map("is_current")
  // Cascading: when set, all other sessions in same school get isCurrent=false
  activatedAt DateTime? @map("activated_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  metadata Json?

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  school      School         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  terms       AcademicTerm[]
  curricula   Curriculum[]
  sections    Section[]
  enrollments Enrollment[]
  holidays    Holiday[]

  @@unique([schoolId, code])
  @@index([schoolId, status])
  @@index([isCurrent])
  @@map("academic_sessions")
}

model AcademicTerm {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  sessionId String @map("session_id") @db.Uuid

  name      String           @db.VarChar(80) // 'Quarter 1', 'Semester 2'
  type      AcademicTermType
  order     Int // 1-based order within session
  startDate DateTime         @map("start_date") @db.Date
  endDate   DateTime         @map("end_date") @db.Date
  isCurrent Boolean          @default(false) @map("is_current")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  session     AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reportCards ReportCard[]
  assessments Assessment[]

  @@unique([sessionId, order])
  @@index([sessionId, isCurrent])
  @@map("academic_terms")
}

model Holiday {
  id        String  @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  sessionId String  @map("session_id") @db.Uuid
  branchId  String? @map("branch_id") @db.Uuid // null = applies to all branches

  name        String   @db.VarChar(160)
  description String?  @db.Text
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  type        String   @db.VarChar(40) // 'PUBLIC', 'SCHOOL', 'RELIGIOUS', 'GOVERNMENT'
  isRecurring Boolean  @default(false) @map("is_recurring")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  branch  Branch?         @relation(fields: [branchId], references: [id])

  @@index([sessionId, branchId])
  @@index([startDate, endDate])
  @@map("holidays")
}

model Subject {
  id       String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid

  name        String          @db.VarChar(120)
  code        String          @db.VarChar(32) // 'ENG', 'MATH', 'EVS'
  category    SubjectCategory @default(CORE)
  description String?         @db.Text
  iconUrl     String?         @map("icon_url") @db.VarChar(512)
  color       String?         @db.VarChar(9)
  isDefault   Boolean         @default(false) @map("is_default") // included in every curriculum
  sortOrder   Int             @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  school           School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  curriculumUnits  CurriculumUnit[]
  sectionSubjects  SectionSubject[]
  sectionTeachers  SectionTeacher[]  @relation("section_teacher_subject")
  assessmentItems  AssessmentItem[]
  learningOutcomes LearningOutcome[]

  @@unique([schoolId, code])
  @@index([schoolId, category])
  @@map("subjects")
}

model Curriculum {
  id          String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  sessionId   String @map("session_id") @db.Uuid
  schoolId    String @map("school_id") @db.Uuid
  branchId    String @map("branch_id") @db.Uuid
  classroomId String @map("classroom_id") @db.Uuid

  name        String           @db.VarChar(160) // 'Nursery Curriculum 2025-26'
  description String?          @db.Text
  status      CurriculumStatus @default(DRAFT)
  gradeLevel  String           @map("grade_level") @db.VarChar(32) // 'NURSERY', 'LKG', 'UKG'

  objectives  Json? // [{code, description}]
  pedagogy    String?   @db.Text
  publishedAt DateTime? @map("published_at") @db.Timestamptz
  publishedBy String?   @map("published_by") @db.Uuid

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  session     AcademicSession  @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  branch      Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  classroom   Classroom        @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  units       CurriculumUnit[]
  lessonPlans LessonPlan[]
  sections    Section[]
  school      School           @relation(fields: [schoolId], references: [id])

  @@unique([sessionId, branchId, classroomId])
  @@index([status])
  @@map("curricula")
}

model CurriculumUnit {
  id           String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  curriculumId String @map("curriculum_id") @db.Uuid
  subjectId    String @map("subject_id") @db.Uuid

  name               String    @db.VarChar(160)
  code               String?   @db.VarChar(32)
  description        String?   @db.Text
  order              Int       @default(0)
  durationWeeks      Int       @default(2) @map("duration_weeks")
  startDate          DateTime? @map("start_date") @db.Date
  endDate            DateTime? @map("end_date") @db.Date
  objectives         Json? // [{code, description, bloomLevel}]
  materials          Json? // [{name, qty, notes}]
  activities         Json? // [{name, type, duration, instructions}]
  assessmentCriteria String?   @db.Text

  status String @default("ACTIVE") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  curriculum  Curriculum   @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  lessonPlans LessonPlan[]

  @@index([curriculumId, order])
  @@index([subjectId])
  @@map("curriculum_units")
}

model LessonPlan {
  id           String  @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  curriculumId String  @map("curriculum_id") @db.Uuid
  unitId       String? @map("unit_id") @db.Uuid
  sectionId    String? @map("section_id") @db.Uuid

  title           String           @db.VarChar(160)
  summary         String?          @db.Text
  objectives      Json? // [{code, description}]
  materials       Json?
  procedure       String?          @db.Text
  durationMinutes Int              @default(30) @map("duration_minutes")
  plannedDate     DateTime         @map("planned_date") @db.Date
  status          LessonPlanStatus @default(DRAFT)
  deliveredAt     DateTime?        @map("delivered_at") @db.Timestamptz
  deliveredBy     String?          @map("delivered_by") @db.Uuid
  reflectionNotes String?          @map("reflection_notes") @db.Text

  createdBy String    @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  curriculum Curriculum      @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  unit       CurriculumUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  section    Section?        @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([curriculumId, plannedDate])
  @@index([sectionId, plannedDate])
  @@index([status])
  @@map("lesson_plans")
}

model Section {
  id           String  @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId     String  @map("school_id") @db.Uuid
  sessionId    String  @map("session_id") @db.Uuid
  branchId     String  @map("branch_id") @db.Uuid
  classroomId  String  @map("classroom_id") @db.Uuid
  curriculumId String? @map("curriculum_id") @db.Uuid

  name          String @db.VarChar(80) // 'Nursery A'
  code          String @db.VarChar(16) // 'NSY-A'
  gradeLevel    String @map("grade_level") @db.VarChar(32)
  capacity      Int    @default(20)
  enrolledCount Int    @default(0) @map("enrolled_count")
  minAgeMonths  Int    @default(0) @map("min_age_months")
  maxAgeMonths  Int    @default(0) @map("max_age_months")

  status      SectionStatus @default(PLANNED)
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  activatedAt DateTime?     @map("activated_at") @db.Timestamptz
  closedAt    DateTime?     @map("closed_at") @db.Timestamptz

  roomNumber String? @map("room_number") @db.VarChar(16)
  metadata   Json?

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  session      AcademicSession  @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  branch       Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  classroom    Classroom        @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  curriculum   Curriculum?      @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  subjects     SectionSubject[]
  teachers     SectionTeacher[]
  enrollments  Enrollment[]
  observations Observation[]
  assessments  Assessment[]
  lessonPlans  LessonPlan[]
  reportCards  ReportCard[]
  portfolios   Portfolio[]

  @@unique([branchId, code, sessionId])
  @@index([sessionId, status])
  @@index([branchId, status])
  @@map("sections")
}

model SectionSubject {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  sectionId String @map("section_id") @db.Uuid
  subjectId String @map("subject_id") @db.Uuid

  isCore            Boolean @default(true) @map("is_core")
  sessionsPerWeek   Int     @default(3) @map("sessions_per_week")
  minutesPerSession Int     @default(30) @map("minutes_per_session")
  sortOrder         Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([sectionId, subjectId])
  @@map("section_subjects")
}

model SectionTeacher {
  id        String  @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  sectionId String  @map("section_id") @db.Uuid
  subjectId String? @map("subject_id") @db.Uuid
  teacherId String  @map("teacher_id") @db.Uuid // links to users.id (CLASS_TEACHER role)

  role           String    @default("ASSISTANT") @db.VarChar(20) // 'PRIMARY', 'ASSISTANT', 'CO_TEACHER', 'SPECIAL_ED'
  isClassTeacher Boolean   @default(false) @map("is_class_teacher")
  assignedAt     DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  removedAt      DateTime? @map("removed_at") @db.Timestamptz
  notes          String?   @db.Text

  section Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject Subject? @relation("section_teacher_subject", fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([sectionId, teacherId, subjectId])
  @@index([teacherId])
  @@map("section_teachers")
}

model Enrollment {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId  String @map("school_id") @db.Uuid
  studentId String @map("student_id") @db.Uuid
  sessionId String @map("session_id") @db.Uuid
  sectionId String @map("section_id") @db.Uuid

  enrollmentNumber String           @unique @map("enrollment_number") @db.VarChar(32)
  type             EnrollmentType   @default(NEW)
  status           EnrollmentStatus @default(ENROLLED)
  enrolledAt       DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz
  startDate        DateTime         @map("start_date") @db.Date
  endDate          DateTime?        @map("end_date") @db.Date
  exitedAt         DateTime?        @map("exited_at") @db.Timestamptz
  exitReason       String?          @map("exit_reason") @db.Text

  previousSectionId String? @map("previous_section_id") @db.Uuid
  nextSectionId     String? @map("next_section_id") @db.Uuid

  metadata Json?

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  student          Student           @relation(fields: [studentId], references: [id], onDelete: Restrict)
  session          AcademicSession   @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  section          Section           @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  school           School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  observations     Observation[]
  assessmentScores AssessmentScore[]
  reportCards      ReportCard[]
  portfolioItems   PortfolioItem[]
  portfolio        Portfolio?

  @@unique([studentId, sessionId])
  @@index([sectionId, status])
  @@index([studentId, status])
  @@map("enrollments")
}

model Observation {
  id           String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  enrollmentId String @map("enrollment_id") @db.Uuid
  schoolId     String @map("school_id") @db.Uuid
  sectionId    String @map("section_id") @db.Uuid

  observedAt         DateTime            @map("observed_at") @db.Timestamptz
  category           ObservationCategory @default(GENERAL)
  title              String?             @db.VarChar(160)
  description        String              @db.Text
  evidenceUrls       Json?               @map("evidence_urls") // [{type, url, caption}]
  rating             Int? // 1-5 scale
  isPrivate          Boolean             @default(true) @map("is_private") // visible to parent?
  isSharedWithParent Boolean             @default(false) @map("is_shared_with_parent")
  sharedAt           DateTime?           @map("shared_at") @db.Timestamptz

  observedBy String    @map("observed_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  section    Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id])

  @@index([enrollmentId, observedAt])
  @@index([sectionId, observedAt])
  @@index([category])
  @@map("observations")
}

model Assessment {
  id        String  @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId  String  @map("school_id") @db.Uuid
  sectionId String  @map("section_id") @db.Uuid
  termId    String? @map("term_id") @db.Uuid

  name          String           @db.VarChar(160) // 'Q1 Math Assessment'
  type          AssessmentType   @default(FORMATIVE)
  status        AssessmentStatus @default(SCHEDULED)
  description   String?          @db.Text
  totalMarks    Int?             @map("total_marks")
  passingMarks  Int?             @map("passing_marks")
  weightPercent Int              @default(0) @map("weight_percent") // contribution to final grade
  scheduledAt   DateTime?        @map("scheduled_at") @db.Timestamptz
  startedAt     DateTime?        @map("started_at") @db.Timestamptz
  completedAt   DateTime?        @map("completed_at") @db.Timestamptz

  createdBy String    @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  section Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  term    AcademicTerm?     @relation(fields: [termId], references: [id], onDelete: SetNull)
  school  School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  items   AssessmentItem[]
  scores  AssessmentScore[]

  @@index([sectionId, status])
  @@index([termId])
  @@map("assessments")
}

model AssessmentItem {
  id           String  @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  assessmentId String  @map("assessment_id") @db.Uuid
  subjectId    String? @map("subject_id") @db.Uuid

  description       String  @db.Text
  maxMarks          Int     @default(10) @map("max_marks")
  weightPercent     Int     @default(0) @map("weight_percent")
  sortOrder         Int     @default(0) @map("sort_order")
  rubric            Json? // [{level, description, marks}]
  learningOutcomeId String? @map("learning_outcome_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  assessment      Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  subject         Subject?          @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  learningOutcome LearningOutcome?  @relation(fields: [learningOutcomeId], references: [id], onDelete: SetNull)
  scores          AssessmentScore[]

  @@index([assessmentId, sortOrder])
  @@map("assessment_items")
}

model AssessmentScore {
  id           String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  assessmentId String @map("assessment_id") @db.Uuid
  itemId       String @map("item_id") @db.Uuid
  enrollmentId String @map("enrollment_id") @db.Uuid

  marks     Int? // null = absent
  grade     ScoreGrade? // letter grade equivalent
  isAbsent  Boolean     @default(false) @map("is_absent")
  isExcused Boolean     @default(false) @map("is_excused")
  remarks   String?     @db.Text
  scoredAt  DateTime    @default(now()) @map("scored_at") @db.Timestamptz
  scoredBy  String      @map("scored_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  assessment Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  item       AssessmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  enrollment Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([itemId, enrollmentId])
  @@index([assessmentId, enrollmentId])
  @@index([enrollmentId])
  @@map("assessment_scores")
}

model GradeScale {
  id       String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid

  name        String  @db.VarChar(80) // 'Standard Scale', 'CBSE Scale'
  description String? @db.Text
  isDefault   Boolean @default(false) @map("is_default")

  // JSON array: [{grade: 'A_PLUS', minPercent: 90, maxPercent: 100, label: 'Outstanding', gpa: 4.0}]
  scale Json

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  reportCardTemplates ReportCardTemplate[]

  @@unique([schoolId, name])
  @@map("grade_scales")
}

model LearningOutcome {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId  String @map("school_id") @db.Uuid
  subjectId String @map("subject_id") @db.Uuid

  code        String          @db.VarChar(40) // 'LO-NUR-ENG-001'
  description String          @db.Text
  domain      MilestoneDomain @default(COGNITIVE)
  bloomLevel  String?         @map("bloom_level") @db.VarChar(40) // 'REMEMBER', 'UNDERSTAND', etc.
  gradeLevel  String          @map("grade_level") @db.VarChar(32)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school          School           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  subject         Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  assessmentItems AssessmentItem[]

  @@unique([subjectId, code])
  @@index([gradeLevel])
  @@map("learning_outcomes")
}

model ReportCardTemplate {
  id           String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId     String @map("school_id") @db.Uuid
  gradeScaleId String @map("grade_scale_id") @db.Uuid

  name        String  @db.VarChar(120) // 'Nursery Standard Report Card'
  gradeLevel  String  @map("grade_level") @db.VarChar(32)
  description String? @db.Text
  // Sections: [{title, type: 'SUBJECT'|'CO_CURRICULAR'|'DEVELOPMENTAL'|'COMMENT', fields: [{name, type, label}]}]
  structure   Json
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  gradeScale  GradeScale   @relation(fields: [gradeScaleId], references: [id], onDelete: Restrict)
  reportCards ReportCard[]

  @@index([schoolId, gradeLevel, isActive])
  @@map("report_card_templates")
}

model ReportCard {
  id           String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  enrollmentId String @map("enrollment_id") @db.Uuid
  schoolId     String @map("school_id") @db.Uuid
  sectionId    String @map("section_id") @db.Uuid
  termId       String @map("term_id") @db.Uuid
  templateId   String @map("template_id") @db.Uuid

  status            ReportCardStatus @default(DRAFT)
  // Generated JSON per template structure: {sections: [{title, fields: [{name, value, grade}]}]}
  content           Json
  overallGrade      String?          @map("overall_grade") @db.VarChar(8)
  attendanceSummary Json?            @map("attendance_summary") // {totalDays, present, absent, late}
  teacherComment    String?          @map("teacher_comment") @db.Text
  principalComment  String?          @map("principal_comment") @db.Text
  generatedAt       DateTime?        @map("generated_at") @db.Timestamptz
  publishedAt       DateTime?        @map("published_at") @db.Timestamptz
  sharedAt          DateTime?        @map("shared_at") @db.Timestamptz

  generatedBy String? @map("generated_by") @db.Uuid
  publishedBy String? @map("published_by") @db.Uuid

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  enrollment Enrollment         @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  section    Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  term       AcademicTerm       @relation(fields: [termId], references: [id], onDelete: Restrict)
  template   ReportCardTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  school     School             @relation(fields: [schoolId], references: [id])

  @@unique([enrollmentId, termId])
  @@index([sectionId, termId, status])
  @@map("report_cards")
}

model Portfolio {
  id           String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  enrollmentId String @unique @map("enrollment_id") @db.Uuid
  schoolId     String @map("school_id") @db.Uuid
  sectionId    String @map("section_id") @db.Uuid

  title              String  @db.VarChar(160)
  description        String? @db.Text
  coverImageUrl      String? @map("cover_image_url") @db.VarChar(512)
  itemCount          Int     @default(0) @map("item_count")
  isSharedWithParent Boolean @default(true) @map("is_shared_with_parent")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  enrollment Enrollment      @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  section    Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items      PortfolioItem[]
  school     School          @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  @@index([sectionId])
  @@map("portfolios")
}

model PortfolioItem {
  id           String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  portfolioId  String @map("portfolio_id") @db.Uuid
  enrollmentId String @map("enrollment_id") @db.Uuid

  type               PortfolioItemType
  title              String            @db.VarChar(160)
  description        String?           @db.Text
  // S3 keys for media
  s3ObjectKey        String?           @map("s3_object_key") @db.VarChar(512)
  thumbnailUrl       String?           @map("thumbnail_url") @db.VarChar(512)
  capturedAt         DateTime          @map("captured_at") @db.Timestamptz
  capturedBy         String            @map("captured_by") @db.Uuid
  // Tags for search/filter
  tags               String[]          @default([])
  // Linked developmental milestones
  milestoneIds       String[]          @default([]) @map("milestone_ids")
  isHighlight        Boolean           @default(false) @map("is_highlight")
  isSharedWithParent Boolean           @default(true) @map("is_shared_with_parent")
  sortOrder          Int               @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  portfolio  Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([portfolioId, capturedAt])
  @@index([type])
  @@index([isHighlight])
  @@map("portfolio_items")
}

model Milestone {
  id       String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid

  code               String          @db.VarChar(40) // 'MS-PHYS-24M-001'
  name               String          @db.VarChar(160)
  description        String          @db.Text
  domain             MilestoneDomain
  ageRangeMin        Int             @map("age_range_min") // months
  ageRangeMax        Int             @map("age_range_max")
  // Expected age in months when this milestone is typically achieved
  expectedAgeMonths  Int             @map("expected_age_months")
  redFlagAgeMonths   Int?            @map("red_flag_age_months") // consult specialist if not achieved by this age
  assessmentCriteria String?         @db.Text

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school       School                 @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  achievements MilestoneAchievement[]

  @@unique([code])
  @@index([domain, ageRangeMin])
  @@map("milestones")
}

model MilestoneAchievement {
  id          String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  studentId   String @map("student_id") @db.Uuid
  milestoneId String @map("milestone_id") @db.Uuid

  status                 MilestoneStatus @default(NOT_OBSERVED)
  observedAt             DateTime?       @map("observed_at") @db.Timestamptz
  observedBy             String?         @map("observed_by") @db.Uuid
  ageAtObservationMonths Int?            @map("age_at_observation_months")
  notes                  String?         @db.Text
  evidenceUrls           Json?           @map("evidence_urls")
  isRedFlag              Boolean         @default(false) @map("is_red_flag")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Restrict)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, milestoneId])
  @@index([studentId])
  @@index([isRedFlag])
  @@map("milestone_achievements")
}

