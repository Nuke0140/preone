model Lead {
  id                     String           @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId               String           @map("school_id") @db.Uuid
  branchId               String?          @map("branch_id") @db.Uuid
  leadCode               String           @map("lead_code") @db.VarChar(32)
  parentFirstName        String           @map("parent_first_name") @db.VarChar(100)
  parentLastName         String           @map("parent_last_name") @db.VarChar(100)
  email                  String?          @db.VarChar(255)
  phone                  String           @db.VarChar(20)
  alternatePhone         String?          @map("alternate_phone") @db.VarChar(20)
  childName              String?          @map("child_name") @db.VarChar(100)
  childDateOfBirth       DateTime?        @map("child_date_of_birth") @db.Date
  programInterest        ProgramInterest  @map("program_interest")
  preferredStartDate     DateTime?        @map("preferred_start_date") @db.Date
  source                 LeadSource
  sourceDetails          String?          @map("source_details") @db.Text
  campaignId             String?          @map("campaign_id") @db.Uuid
  status                 LeadStatus       @default(NEW)
  priority               LeadPriority     @default(WARM)
  assignedCounsellorId   String?          @map("assigned_counsellor_id") @db.Uuid
  previousCounsellorId   String?          @map("previous_counsellor_id") @db.Uuid
  assignedAt             DateTime?        @map("assigned_at") @db.Timestamptz
  firstContactedAt       DateTime?        @map("first_contacted_at") @db.Timestamptz
  lastContactedAt        DateTime?        @map("last_contacted_at") @db.Timestamptz
  contactCount           Int              @default(0) @map("contact_count")
  qualificationScore     Int?             @map("qualification_score")
  qualificationNotes     String?          @map("qualification_notes") @db.Text
  convertedAt            DateTime?        @map("converted_at") @db.Timestamptz
  convertedApplicationId String?          @map("converted_application_id") @db.Uuid
  convertedStudentId     String?          @map("converted_student_id") @db.Uuid
  lostReason             String?          @map("lost_reason") @db.Text
  lostAt                 DateTime?        @map("lost_at") @db.Timestamptz
  budgetCents            Int?             @map("budget_cents")
  location               String?          @db.VarChar(255)
  notes                  String?          @db.Text
  tags                   String[]         @default([])
  followUpCount          Int              @default(0) @map("follow_up_count")
  followUps              FollowUp[]
  activities             LeadActivity[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school              School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch              Branch?   @relation(fields: [branchId], references: [id])
  campaign            Campaign? @relation(fields: [campaignId], references: [id])
  assignedCounsellor  User?     @relation("LeadAssignedCounsellor", fields: [assignedCounsellorId], references: [id])
  previousCounsellor  User?     @relation("LeadPreviousCounsellor", fields: [previousCounsellorId], references: [id])

  @@unique([schoolId, leadCode])
  @@index([schoolId, status])
  @@index([schoolId, source])
  @@index([assignedCounsellorId])
  @@index([campaignId])
  @@map("leads")
}

model Campaign {
  id                     String           @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId               String           @map("school_id") @db.Uuid
  branchId               String?          @map("branch_id") @db.Uuid
  campaignCode           String           @map("campaign_code") @db.VarChar(32)
  name                   String           @db.VarChar(200)
  description            String?          @db.Text
  channel                CampaignChannel
  audience               CampaignAudience
  customSegmentQuery     String?          @map("custom_segment_query") @db.Text
  status                 CampaignStatus   @default(DRAFT)
  budgetCents            Int              @map("budget_cents")
  spentCents             Int              @default(0) @map("spent_cents")
  audienceSize           Int              @default(0) @map("audience_size")
  sentCount              Int              @default(0) @map("sent_count")
  deliveredCount         Int              @default(0) @map("delivered_count")
  openedCount            Int              @default(0) @map("opened_count")
  clickedCount           Int              @default(0) @map("clicked_count")
  convertedCount         Int              @default(0) @map("converted_count")
  templateId             String?          @map("template_id") @db.Uuid
  messageContent         String?          @map("message_content") @db.Text
  scheduledAt            DateTime?        @map("scheduled_at") @db.Timestamptz
  launchedAt             DateTime?        @map("launched_at") @db.Timestamptz
  completedAt            DateTime?        @map("completed_at") @db.Timestamptz
  cancelledAt            DateTime?        @map("cancelled_at") @db.Timestamptz
  cancellationReason     String?          @map("cancellation_reason") @db.Text
  attributedRevenueCents Int              @default(0) @map("attributed_revenue_cents")
  leads                  Lead[]
  followUps              FollowUp[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([schoolId, campaignCode])
  @@index([schoolId, status])
  @@map("campaigns")
}

model FollowUp {
  id                    String          @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId              String          @map("school_id") @db.Uuid
  branchId              String?         @map("branch_id") @db.Uuid
  leadId                String          @map("lead_id") @db.Uuid
  campaignId            String?         @map("campaign_id") @db.Uuid
  counsellorId          String          @map("counsellor_id") @db.Uuid
  type                  FollowUpType
  status                FollowUpStatus  @default(SCHEDULED)
  scheduledAt           DateTime        @map("scheduled_at") @db.Timestamptz
  durationMinutes       Int?            @map("duration_minutes")
  outcome               FollowUpOutcome?
  outcomeNotes          String?         @map("outcome_notes") @db.Text
  startedAt             DateTime?       @map("started_at") @db.Timestamptz
  completedAt           DateTime?       @map("completed_at") @db.Timestamptz
  cancelledAt           DateTime?       @map("cancelled_at") @db.Timestamptz
  cancellationReason    String?         @map("cancellation_reason") @db.Text
  missedAt              DateTime?       @map("missed_at") @db.Timestamptz
  rescheduledTo         DateTime?       @map("rescheduled_to") @db.Timestamptz
  rescheduledFollowUpId String?         @map("rescheduled_follow_up_id") @db.Uuid
  reminderSentCount     Int             @default(0) @map("reminder_sent_count")
  lastReminderSentAt    DateTime?       @map("last_reminder_sent_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  lead        Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  counsellor  User   @relation(fields: [counsellorId], references: [id])
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  school      School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([counsellorId, status])
  @@index([schoolId, scheduledAt])
  @@map("follow_ups")
}

model LeadTag {
  id        String @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId  String @map("school_id") @db.Uuid
  leadId    String @map("lead_id") @db.Uuid
