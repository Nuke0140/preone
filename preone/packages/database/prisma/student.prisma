  transferCertificateUrl String?
  requestedAt            DateTime
  approvedAt             DateTime?
  completedAt            DateTime?
  createdAt              DateTime       @default(now())
  createdBy              String?
  updatedAt              DateTime       @updatedAt
  updatedBy              String?
  deletedAt              DateTime?
  deletedBy              String?
  version                Int            @default(1)

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("transfers")
}

