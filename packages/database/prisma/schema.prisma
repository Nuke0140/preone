// PreOne Prisma Schema v3.0
// ===========================
// Database: PostgreSQL 16 (HA via Patroni + 2 read replicas)
// Multi-tenancy: Shared schema with school_id discriminator + RLS
//
// Scope (per ERD v3.0):
//   14 domains + Cross-Cutting + Platform Management = 15 domains
//   307 tables • 84 enums • 412 FKs
//
// This file is being built up progressively.
// Current coverage: Platform Management + Core (Auth & Org) foundation.
//
// Naming conventions (per ERD v3.0 §3):
//   - Tables: snake_case plural (students, audit_log)
//   - Columns: snake_case (school_id, created_at)
//   - FKs: <entity>_id suffix
//   - Indexes: <table>_<columns>_idx (or _uidx for unique, _p for partial)
//   - Enums: PascalCase singular type (AttendanceStatus); values UPPER_SNAKE
//   - PKs: UUID v7 (time-sortable)
//   - Timestamps: timestamptz (with timezone) — never plain timestamp
//   - Money: integer cents (amount_cents) — never float
//   - Soft delete: deleted_at timestamptz NULL

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS — Platform Management
// ─────────────────────────────────────────────

enum SubscriptionPlan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

enum BillingStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum BackupType {
  AUTO
  MANUAL
  SNAPSHOT
}

enum IntegrationType {
  WHATSAPP_BUSINESS
  RAZORPAY
  MSG91
  TWILIO
  ESSL_BIOMETRIC
  TALLY
  ZOHO_BOOKS
  QUICKBOOKS
  CUSTOM
}

// ─────────────────────────────────────────────
// ENUMS — Core (Auth & Org)
// ─────────────────────────────────────────────

enum SchoolStatus {
  PROSPECT
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SchoolTier {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum RoleScope {
  PLATFORM
  TENANT
  BRANCH
  CLASSROOM
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OtpPurpose {
  LOGIN
  PHONE_VERIFICATION
  PASSWORD_RESET
  MFA_CHALLENGE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

// ─────────────────────────────────────────────
// MODEL: school (TENANT ANCHOR — per ERD §11.4.2)
// ─────────────────────────────────────────────

model School {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  name            String        @db.VarChar(120)
  legalName       String?       @map("legal_name") @db.VarChar(200)
  email           String        @unique @db.Citext
  phone           String        @db.VarChar(16)
  website         String?       @db.VarChar(255)
  gstNumber       String?       @unique @map("gst_number") @db.VarChar(15)
  panNumber       String?       @unique @map("pan_number") @db.VarChar(10)

  status          SchoolStatus  @default(PROSPECT)
  tier            SchoolTier    @default(STARTER)
  branchCount     Int           @default(0) @map("branch_count")
  maxBranches     Int           @default(1) @map("max_branches")
  studentSeats    Int           @default(100) @map("student_seats")
  usedSeats       Int           @default(0) @map("used_seats")

  logoUrl         String?       @map("logo_url") @db.VarChar(512)
  timezone        String        @default("Asia/Kolkata") @db.VarChar(64)
  locale          String        @default("en-IN") @db.VarChar(16)

  trialEndsAt     DateTime?     @map("trial_ends_at") @db.Timestamptz
  activatedAt     DateTime?     @map("activated_at") @db.Timestamptz
  suspendedAt     DateTime?     @map("suspended_at") @db.Timestamptz
  cancelledAt     DateTime?     @map("cancelled_at") @db.Timestamptz

  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  // ─── Relations ───
  branches        Branch[]
  users           User[]
  roles           Role[]
  sessions        Session[]
  otpChallenges   OtpChallenge[]
  subscription    SchoolSubscription?
  integrations    PlatformIntegration[]
  featureFlags    FeatureFlag[]
  auditLogs       AuditLog[]

  @@index([status])
  @@index([tier])
  @@index([createdAt])
  @@map("schools")
}

// ─────────────────────────────────────────────
// MODEL: branch (per ERD §11.4.3)
// ─────────────────────────────────────────────

model Branch {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  code            String        @db.VarChar(8)       // BR-001, BR-002
  name            String        @db.VarChar(120)
  addressLine1    String        @map("address_line1") @db.VarChar(255)
  addressLine2    String?       @map("address_line2") @db.VarChar(255)
  city            String        @db.VarChar(64)
  state           String        @db.VarChar(64)
  pincode         String        @db.VarChar(6)
  country         String        @default("India") @db.VarChar(64)

  latitude        Decimal?      @db.Decimal(10, 7)
  longitude       Decimal?      @db.Decimal(10, 7)
  googlePlaceId   String?       @map("google_place_id") @db.VarChar(255)

  phone           String        @db.VarChar(16)
  email           String?       @db.Citext
  timezone        String        @default("Asia/Kolkata") @db.VarChar(64)
  locale          String        @default("en-IN") @db.VarChar(16)

  isActive        Boolean       @default(true) @map("is_active")
  openedAt        DateTime?     @map("opened_at") @db.Date
  closedAt        DateTime?     @map("closed_at") @db.Date

  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  // ─── Relations ───
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  users           User[]
  classrooms      Classroom[]
  auditLogs       AuditLog[]

  @@unique([schoolId, code])
  @@index([schoolId, isActive])
  @@index([city, state])
  @@map("branches")
}

// ─────────────────────────────────────────────
// MODEL: user (per ERD §11.4.4)
// ─────────────────────────────────────────────

model User {
  id                String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId          String        @map("school_id") @db.Uuid
  branchId          String?       @map("branch_id") @db.Uuid

  email             String        @db.Citext
  phone             String?       @db.VarChar(16)
  passwordHash      String?       @map("password_hash") @db.VarChar(255)  // argon2id

  firstName         String        @map("first_name") @db.VarChar(80)
  lastName          String        @map("last_name") @db.VarChar(80)
  displayName       String?       @map("display_name") @db.VarChar(160)
  avatarUrl         String?       @map("avatar_url") @db.VarChar(512)
  gender            Gender        @default(UNSPECIFIED)

  status            UserStatus    @default(PENDING)
  permissionsVersion Int          @default(1) @map("permissions_version")

  academicYearId    String?       @map("academic_year_id") @db.Uuid
  lastLoginAt       DateTime?     @map("last_login_at") @db.Timestamptz
  lastLoginIp       String?       @map("last_login_ip") @db.VarChar(45)
  emailVerifiedAt   DateTime?     @map("email_verified_at") @db.Timestamptz
  phoneVerifiedAt   DateTime?     @map("phone_verified_at") @db.Timestamptz
  mfaEnabled        Boolean       @default(false) @map("mfa_enabled")
  mfaSecret         String?       @map("mfa_secret") @db.VarChar(255)

  locale            String        @default("en-IN") @db.VarChar(16)
  timezone          String        @default("Asia/Kolkata") @db.VarChar(64)

  version           Int           @default(1)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamptz

  // ─── Relations ───
  school            School        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  branch            Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  roles             UserRole[]
  sessions          Session[]
  refreshTokens     RefreshToken[]
  otpChallenges     OtpChallenge[]
  auditLogs         AuditLog[]

  @@unique([schoolId, email])
  @@index([schoolId, status])
  @@index([phone])
  @@index([branchId])
  @@map("users")
}

// ─────────────────────────────────────────────
// MODEL: role (per ERD §11.4.5)
// ─────────────────────────────────────────────

model Role {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String?       @map("school_id") @db.Uuid  // NULL for platform roles
  code            String        @db.VarChar(32)
  name            String        @db.VarChar(80)
  description     String?       @db.Text
  scope           RoleScope     @default(TENANT)
  isSystem        Boolean       @default(false) @map("is_system")
  color           String?       @db.VarChar(7)   // hex color for UI badge
  sortOrder       Int           @default(100) @map("sort_order")
  isActive        Boolean       @default(true) @map("is_active")

  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  // ─── Relations ───
  school          School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  users           UserRole[]

  @@unique([schoolId, code])
  @@index([schoolId, isActive])
  @@map("roles")
}

// ─────────────────────────────────────────────
// MODEL: permission (per ERD §11.4.6)
// ─────────────────────────────────────────────

model Permission {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  code            String        @unique @db.VarChar(80)   // 'students.create.execute'
  name            String        @db.VarChar(120)
  description     String?       @db.Text
  module          String        @db.VarChar(64)            // 'student', 'finance'
  action          String        @db.VarChar(32)            // 'create','read','update','delete','execute','approve','reject','export','assign','configure'
  resource        String        @db.VarChar(64)            // 'student', 'invoice'
  scopeType       String        @default("TENANT") @db.VarChar(16) @map("scope_type")
  abacCondition   Json?         @map("abac_condition")     // ABAC rule JSON
  isDangerous     Boolean       @default(false) @map("is_dangerous")

  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // ─── Relations ───
  roles           RolePermission[]

  @@index([module, action])
  @@index([resource])
  @@map("permissions")
}

// ─────────────────────────────────────────────
// MODEL: role_permission (per ERD §11.4.7)
// ─────────────────────────────────────────────

model RolePermission {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  roleId          String        @map("role_id") @db.Uuid
  permissionId    String        @map("permission_id") @db.Uuid
  grantedBy       String?       @map("granted_by") @db.Uuid
  grantedAt       DateTime      @default(now()) @map("granted_at") @db.Timestamptz
  expiresAt       DateTime?     @map("expires_at") @db.Timestamptz

  role            Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permission")
}

// ─────────────────────────────────────────────
// MODEL: user_role (per ERD §11.4.8)
// Hybrid Assignment Model — ADR v1.0
// ─────────────────────────────────────────────

model UserRole {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  roleId          String        @map("role_id") @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  branchId        String?       @map("branch_id") @db.Uuid
  classroomId     String?       @map("classroom_id") @db.Uuid
  academicYearId  String?       @map("academic_year_id") @db.Uuid
  assignedBy      String?       @map("assigned_by") @db.Uuid
  assignedAt      DateTime      @default(now()) @map("assigned_at") @db.Timestamptz
  expiresAt       DateTime?     @map("expires_at") @db.Timestamptz

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, schoolId, branchId, classroomId])
  @@index([schoolId, roleId])
  @@index([userId])
  @@index([branchId])
  @@map("user_role")
}

// ─────────────────────────────────────────────
// MODEL: session (per ERD §11.4.9)
// ─────────────────────────────────────────────

model Session {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  branchId        String?       @map("branch_id") @db.Uuid
  sessionToken    String        @unique @map("session_token") @db.VarChar(128)
  status          SessionStatus @default(ACTIVE)
  ipAddress       String?       @map("ip_address") @db.VarChar(45)
  userAgent       String?       @map("user_agent") @db.Text
  issuedAt        DateTime      @default(now()) @map("issued_at") @db.Timestamptz
  lastUsedAt      DateTime      @default(now()) @map("last_used_at") @db.Timestamptz
  expiresAt       DateTime      @map("expires_at") @db.Timestamptz
  revokedAt       DateTime?     @map("revoked_at") @db.Timestamptz
  revokedReason   String?       @map("revoked_reason") @db.VarChar(120)

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([schoolId, status])
  @@index([expiresAt])
  @@map("sessions")
}

// ─────────────────────────────────────────────
// MODEL: refresh_token (per ERD §11.4.10)
// ─────────────────────────────────────────────

model RefreshToken {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  tokenHash       String        @unique @map("token_hash") @db.VarChar(128)
  parentTokenHash String?       @map("parent_token_hash") @db.VarChar(128)
  issuedAt        DateTime      @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt       DateTime      @map("expires_at") @db.Timestamptz
  revokedAt       DateTime?     @map("revoked_at") @db.Timestamptz
  revokedReason   String?       @map("revoked_reason") @db.VarChar(120)
  userAgent       String?       @map("user_agent") @db.Text
  ipAddress       String?       @map("ip_address") @db.VarChar(45)

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// MODEL: otp_challenge (per ERD §11.4.11)
// ─────────────────────────────────────────────

model OtpChallenge {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String?       @map("school_id") @db.Uuid
  userId          String?       @map("user_id") @db.Uuid
  channel         String        @db.VarChar(8)   // 'EMAIL' | 'PHONE'
  target          String        @db.VarChar(255)
  codeHash        String        @map("code_hash") @db.VarChar(128)
  purpose         OtpPurpose    @default(LOGIN)
  attempts        Int           @default(0)
  maxAttempts     Int           @default(3) @map("max_attempts")
  verifiedAt      DateTime?     @map("verified_at") @db.Timestamptz
  expiresAt       DateTime      @map("expires_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([target, purpose])
  @@index([expiresAt])
  @@map("otp_challenges")
}

// ─────────────────────────────────────────────
// MODEL: audit_log (per ERD §11.4.12) — partitioned monthly per ERD §8.2
// ─────────────────────────────────────────────

model AuditLog {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  occurredAt      DateTime      @default(now()) @map("occurred_at") @db.Timestamptz
  userId          String?       @map("user_id") @db.Uuid
  schoolId        String?       @map("school_id") @db.Uuid
  branchId        String?       @map("branch_id") @db.Uuid
  action          String        @db.VarChar(32)
  module          String        @db.VarChar(64)
  entity          String        @db.VarChar(64)
  entityId        String?       @map("entity_id") @db.Uuid
  oldValues       Json?         @map("old_values")
  newValues       Json?         @map("new_values")
  ipAddress       String?       @map("ip_address") @db.VarChar(45)
  userAgent       String?       @map("user_agent") @db.Text
  requestId       String?       @map("request_id") @db.VarChar(64)
  traceId         String?       @map("trace_id") @db.VarChar(64)
  metadata        Json?

  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  school          School?       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  branch          Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([schoolId, entity, entityId])
  @@index([userId, occurredAt])
  @@index([traceId])
  @@map("audit_log")
}

// ─────────────────────────────────────────────
// MODEL: feature_flag (per ERD §11.4.13) — 3-Level: Platform AND School AND Plan
// ─────────────────────────────────────────────

model FeatureFlag {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String?       @map("school_id") @db.Uuid
  key             String        @db.VarChar(80)
  value           Json
  scope           String        @db.VarChar(16)  // PLATFORM | SCHOOL | PLAN
  plan            String?       @db.VarChar(32)
  description     String?       @db.Text
  changedBy       String?       @map("changed_by") @db.Uuid
  changedAt       DateTime      @default(now()) @map("changed_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  school          School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, key, scope, plan])
  @@index([key])
  @@map("feature_flags")
}

// ─────────────────────────────────────────────
// MODEL: school_subscription (per ERD §10.4.2)
// ─────────────────────────────────────────────

model SchoolSubscription {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String        @unique @map("school_id") @db.Uuid

  plan            SubscriptionPlan @default(STARTER)
  status          SubscriptionStatus @default(TRIAL)
  billingPeriod   BillingPeriod @default(MONTHLY) @map("billing_period")
  startedAt       DateTime      @map("started_at") @db.Timestamptz
  renewsAt        DateTime      @map("renews_at") @db.Timestamptz
  trialEndsAt     DateTime?     @map("trial_ends_at") @db.Timestamptz

  seatsIncluded   Int           @map("seats_included")
  amountCents     Int           @map("amount_cents")
  currency        String        @default("INR") @db.VarChar(3)
  cancelledAt     DateTime?     @map("cancelled_at") @db.Timestamptz
  cancelReason    String?       @map("cancel_reason") @db.Text

  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  school          School        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  billings        PlatformBilling[]

  @@index([status])
  @@index([renewsAt])
  @@map("school_subscriptions")
}

model PlatformBilling {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  subscriptionId  String        @map("subscription_id") @db.Uuid
  invoiceNumber   String        @unique @map("invoice_number") @db.VarChar(32)
  amountCents     Int           @map("amount_cents")
  taxCents        Int           @map("tax_cents")
  totalCents      Int           @map("total_cents")
  billingPeriod   BillingPeriod @map("billing_period")
  periodStart     DateTime      @map("period_start") @db.Date
  periodEnd       DateTime      @map("period_end") @db.Date
  status          BillingStatus @default(PENDING)
  paidAt          DateTime?     @map("paid_at") @db.Timestamptz
  transactionRef  String?       @map("transaction_ref") @db.VarChar(64)
  gatewayResponse Json?         @map("gateway_response")

  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  subscription    SchoolSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([subscriptionId])
  @@map("platform_billing")
}

model PlatformIntegration {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  type            IntegrationType
  name            String        @db.VarChar(80)
  credentials     Bytes
  config          Json
  isActive        Boolean       @default(true) @map("is_active")
  lastSyncedAt    DateTime?     @map("last_synced_at") @db.Timestamptz
  lastSyncStatus  String?       @map("last_sync_status") @db.VarChar(32)

  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, type])
  @@index([isActive])
  @@map("platform_integrations")
}

// ─────────────────────────────────────────────
// MODEL: classroom (per ERD §14.4.12) — placeholder until Student module
// ─────────────────────────────────────────────

model Classroom {
  id              String        @id @default(dbgenerated("uuid_v7()")) @db.Uuid
  branchId        String        @map("branch_id") @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid

  name            String        @db.VarChar(80)
  code            String        @db.VarChar(16)
  gradeLevel      String        @db.VarChar(32) @map("grade_level")
  capacity        Int           @default(20)
  enrolledCount   Int           @default(0) @map("enrolled_count")
  minAgeMonths    Int           @map("min_age_months")
  maxAgeMonths    Int           @map("max_age_months")

  roomNumber      String?       @map("room_number") @db.VarChar(16)
  isActive        Boolean       @default(true) @map("is_active")

  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("classrooms")
}

