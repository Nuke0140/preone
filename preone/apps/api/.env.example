# PreOne API — Environment Variables
# Copy to .env.local and fill in real values.

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
RATE_LIMIT_PER_MINUTE=100
LOKI_HOST=http://localhost:3100

# ─────────────────────────────────────────────
# JWT (use RSA keys — generate with:
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# )
# ─────────────────────────────────────────────
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=30d
JWT_ISSUER=preone.api
JWT_AUDIENCE=preone.app
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars

BODY_LIMIT=50mb

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL 16)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://preone:preone@localhost:5432/preone?schema=public
DATABASE_READ_REPLICA_URL=
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30000
DATABASE_STATEMENT_TIMEOUT=5000

# ─────────────────────────────────────────────
# REDIS (7.2)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_NODES=
REDIS_SENTINEL_PASSWORD=
REDIS_KEY_PREFIX=preone:

# ─────────────────────────────────────────────
# S3 / Object Storage
# ─────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET=preone-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# MinIO local: S3_ENDPOINT=http://localhost:9000 + S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PRESIGN_EXPIRY=3600

# ─────────────────────────────────────────────
# BULLMQ
# ─────────────────────────────────────────────
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3
BULLMQ_BACKOFF_TYPE=exponential
BULLMQ_BACKOFF_DELAY=1000

# ─────────────────────────────────────────────
# OTP
# ─────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# ─────────────────────────────────────────────
# MSG91 (SMS via DLT-approved sender)
# ─────────────────────────────────────────────
MSG91_API_KEY=
MSG91_SENDER_ID=PREONE
MSG91_TEMPLATE_ID=

# ─────────────────────────────────────────────
# WhatsApp Cloud API
# ─────────────────────────────────────────────
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─────────────────────────────────────────────
# Razorpay (Payments)
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# OpenTelemetry
# ─────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=preone-api
OTEL_TRACES_SAMPLER_RATIO=1.0
